---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroHome from '@/components/sections/HeroHome.astro';
import ServicesOverview from '@/components/sections/ServicesOverview.astro';
import TrustSection from '@/components/sections/TrustSection.astro';
import ProcessSection from '@/components/sections/ProcessSection.astro';
import FAQSection from '@/components/sections/FAQSection.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { homeHeroImage } from '@/data/assets';
import { SITE } from '@/data/site';
import { serviceNavigation } from '@/data/navigation';
import { localBusinessSchema, organizationSchema, webPageSchema, websiteSchema } from '@/utils/structuredData';

const title = 'Bauunternehmen in Freilassing für Renovierung & Sanierung';
const description = SITE.defaultDescription;
const services = await getCollection('services');
const servicesBySlug = new Map(services.map((service) => [service.data.slug, service]));
const sortedServices = serviceNavigation
  .filter((item) => !item.optional)
  .map((item) => servicesBySlug.get(item.slug))
  .filter((service): service is (typeof services)[number] => Boolean(service));
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    organizationSchema(),
    localBusinessSchema(),
    websiteSchema(),
    webPageSchema({ title, description, path: '/' }),
  ]}
  image={SITE.ogImage}
  imageAlt={SITE.ogImageAlt}
>
  <HeroHome image={homeHeroImage} />
  <ServicesOverview
    services={sortedServices}
    limit={6}
    title="Leistungen, die Bestand und Alltag zusammenbringen"
    description="Die Startseite zeigt bewusst die Bereiche, die bei Renovierung, Sanierung und Ausbau am häufigsten zusammen gedacht werden: vom Bad über den Innenausbau bis zu sauberen Anschlüssen."
    home
  />
  <TrustSection home />
  <ProcessSection home />
  <FAQSection home />
  <FinalCTA home />
</BaseLayout>
