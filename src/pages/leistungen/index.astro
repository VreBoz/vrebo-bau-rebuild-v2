---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/sections/PageHero.astro';
import ServicesOverview from '@/components/sections/ServicesOverview.astro';
import ProcessSection from '@/components/sections/ProcessSection.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { servicesOverviewImage } from '@/data/assets';
import { serviceNavigation } from '@/data/navigation';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Leistungen für Renovierung & Sanierung in Freilassing';
const description = 'Leistungen von Vrebo Bau für Renovierung, Sanierung, Innenausbau, Badsanierung und objektnahe Arbeiten in Freilassing und Umgebung.';
const services = await getCollection('services');
const servicesBySlug = new Map(services.map((service) => [service.data.slug, service]));
const sortedServices = serviceNavigation
  .filter((item) => !item.optional)
  .map((item) => servicesBySlug.get(item.slug))
  .filter((service): service is (typeof services)[number] => Boolean(service));
const pageActions = [
  { label: 'Projekt anfragen', href: '/kontakt', variant: 'primary' },
  { label: 'Zur Startseite', href: '/', variant: 'secondary' },
] as const;
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    webPageSchema({ title, description, path: '/leistungen' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Leistungen', path: '/leistungen' },
    ]),
  ]}
  image={servicesOverviewImage.src}
  imageAlt={servicesOverviewImage.alt}
>
  <PageHero
    eyebrow="Leistungen"
    title="Leistungen für Renovierung, Sanierung und Ausbau"
    description="Hier finden Sie die wichtigsten Bereiche von Vrebo Bau: klar gegliedert, lokal ausgerichtet und mit kurzen Einstiegen in die einzelnen Leistungen."
    tags={['Freilassing', 'Berchtesgadener Land', 'Renovierung und Ausbau']}
    actions={pageActions}
    mediaLabel="Service-Struktur"
    image={servicesOverviewImage}
  />

  <ServicesOverview
    services={sortedServices}
    eyebrow="Alle Bereiche"
    title="Den passenden Leistungsbereich finden"
    description="Jede Karte führt zur Detailseite mit Umfang, Ablauf und erster Einordnung. Wo noch kein passendes Projektbild vorhanden ist, bleibt die Bildfläche bewusst zurückhaltend."
    compact
    showAllLink={false}
    band
  />

  <ProcessSection />
  <FinalCTA />
</BaseLayout>
