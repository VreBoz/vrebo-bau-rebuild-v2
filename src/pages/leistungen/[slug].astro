---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import LinkArrow from '@/components/ui/LinkArrow.astro';
import Tag from '@/components/ui/Tag.astro';
import { serviceNavigation } from '@/data/navigation';
import { breadcrumbSchema, serviceSchema, webPageSchema } from '@/utils/structuredData';

type Props = {
  service: CollectionEntry<'services'>;
};

export async function getStaticPaths() {
  const services = await getCollection('services');

  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const servicePath = `/leistungen/${service.data.slug}`;
const relatedLinks = service.data.relatedServices
  .map((slug) => serviceNavigation.find((item) => item.slug === slug))
  .filter((item): item is (typeof serviceNavigation)[number] => Boolean(item));
---

<BaseLayout
  title={service.data.seoTitle}
  description={service.data.seoDescription}
  image={service.data.heroImage?.src}
  imageAlt={service.data.heroImage?.alt}
  jsonLd={[
    webPageSchema({
      title: service.data.title,
      description: service.data.seoDescription,
      path: servicePath,
    }),
    serviceSchema(service.data),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Leistungen', path: '/leistungen' },
      { name: service.data.title, path: servicePath },
    ]),
  ]}
>
  <section class="section-shell">
    <div class="site-container service-hero">
      <div class="service-hero__copy">
        <p class="eyebrow">Leistungsdetail</p>
        <h1 class="page-title">{service.data.title}</h1>
        <p class="lede">{service.data.intro}</p>
        <div class="tag-row" aria-label="Leistungs-Tags">
          {service.data.tags.map((tag) => <Tag variant="light">{tag}</Tag>)}
        </div>
        {service.data.areasServed.length > 0 && (
          <p class="service-areas">
            Einsatzgebiet: {service.data.areasServed.slice(0, 4).join(', ')}
          </p>
        )}
        <div class="service-actions">
          <Button href={`/kontakt?leistung=${service.data.slug}`} size="lg">Projekt anfragen</Button>
          <Button href="/leistungen" variant="secondary" size="lg">Alle Leistungen ansehen</Button>
        </div>
      </div>
      <div class:list={['surface', 'service-media', { 'skeleton-panel service-media--empty': !service.data.heroImage }]}>
        {service.data.heroImage ? (
          <img
            src={service.data.heroImage.src}
            alt={service.data.heroImage.alt}
            width={service.data.heroImage.width}
            height={service.data.heroImage.height}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        ) : (
          <span>Bild wird nach passender Projektauswahl ergänzt</span>
        )}
      </div>
    </div>
  </section>

  <section class="section-shell detail-band">
    <div class="site-container detail-grid">
      <article class="surface detail-card">
        <p class="eyebrow">Leistungsumfang</p>
        <h2>Was enthalten sein kann</h2>
        <ul>
          {service.data.servicesIncluded.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="surface detail-card">
        <p class="eyebrow">Ablauf</p>
        <h2>So bleibt der Ablauf geordnet</h2>
        <ol>
          {service.data.processSteps.map((step, index) => (
            <li>
              <em>{String(index + 1).padStart(2, '0')}</em>
              <strong>{step.title}</strong>
              <span>{step.description}</span>
            </li>
          ))}
        </ol>
      </article>
      {service.data.benefits.length > 0 && (
        <article class="surface detail-card detail-card--accent">
          <p class="eyebrow">Worauf wir achten</p>
          <h2>Qualität im Bestand</h2>
          <ul>
            {service.data.benefits.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      )}
    </div>
  </section>

  <section class="section-shell">
    <div class="site-container--narrow prose-shell">
      <p class="eyebrow">Einordnung</p>
      <Content />
    </div>
  </section>

  {relatedLinks.length > 0 && (
    <section class="section-shell--compact related-shell">
      <div class="site-container related-section">
        <div>
          <p class="eyebrow">Verwandte Leistungen</p>
          <h2>Passende Bereiche rund um {service.data.navLabel}</h2>
        </div>
        <div class="related-card-grid" aria-label="Verwandte Leistungen">
          {relatedLinks.map((item) => (
            <article class="related-card">
              <span>{item.navLabel}</span>
              <LinkArrow href={item.href} label={`${item.navLabel} ansehen`}>Ansehen</LinkArrow>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section-shell--compact service-cta-shell">
    <div class="site-container service-cta">
      <div>
        <p class="eyebrow">Anfrage</p>
        <h2>{service.data.navLabel} besprechen</h2>
        <p>
          Beschreiben Sie kurz den Bestand, den gewünschten Umfang und den Ort. So lässt sich besser
          einschätzen, welche nächsten Schritte sinnvoll sind.
        </p>
      </div>
      <div class="service-cta__side">
        <Button href={`/kontakt?leistung=${service.data.slug}`} variant="dark" size="lg">Projekt schildern</Button>
        {relatedLinks.length > 0 && (
          <div class="related-links" aria-label="Verwandte Leistungen">
            <span>Passend dazu</span>
            {relatedLinks.map((item) => <a href={item.href}>{item.navLabel}</a>)}
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(19rem, 0.78fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }

  .service-hero__copy {
    min-width: 0;
  }

  .service-media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3.15;
    min-height: 24rem;
    overflow: hidden;
    background: #e9dfd2;
    color: #6b625c;
    font-weight: 780;
  }

  .service-media::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, transparent 44%, rgb(21 17 15 / 0.16)),
      linear-gradient(90deg, rgb(21 17 15 / 0.1), transparent 44%);
    content: "";
  }

  .service-media img {
    width: 100%;
    height: 100%;
    min-height: 24rem;
    object-fit: cover;
    object-position: center 52%;
  }

  .service-media--empty {
    display: grid;
    place-items: center;
  }

  .service-media--empty::after {
    display: none;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .service-areas {
    margin: 1rem 0 0;
    color: #6b625c;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .service-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .detail-band {
    background:
      linear-gradient(180deg, rgb(244 239 232 / 0.96), rgb(233 223 210 / 0.78)),
      #f4efe8;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .detail-card {
    min-height: 100%;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .detail-card--accent {
    background:
      linear-gradient(145deg, rgb(101 17 19 / 0.075), transparent 46%),
      #fffaf4;
  }

  .detail-card h2,
  .related-section h2 {
    margin: 0;
    color: #2b090b;
    font-size: clamp(1.35rem, 2.2vw, 1.75rem);
    line-height: 1.08;
  }

  ul,
  ol {
    display: grid;
    gap: 0.75rem;
    margin: 1rem 0 0;
    padding-left: 1.2rem;
    color: #6b625c;
    line-height: 1.6;
  }

  ol {
    padding-left: 0;
    list-style: none;
  }

  ol li {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.2rem 0.7rem;
  }

  ol li em {
    grid-row: span 2;
    color: #ab3743;
    font-style: normal;
    font-weight: 820;
  }

  ol li span {
    display: block;
    margin-top: 0.15rem;
  }

  .prose-shell {
    color: #6b625c;
    font-size: 1.06rem;
  }

  .prose-shell :global(h2),
  .prose-shell :global(h3) {
    margin: 2rem 0 0.7rem;
    color: #2b090b;
    line-height: 1.15;
  }

  .prose-shell :global(p) {
    margin: 0 0 1rem;
    line-height: 1.72;
  }

  .related-shell {
    background: #fffaf4;
  }

  .related-section {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr);
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: start;
    border-top: 1px solid rgb(48 43 40 / 0.1);
    padding-top: clamp(2rem, 4vw, 3rem);
  }

  .related-card-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
  }

  .related-card {
    display: grid;
    gap: 1rem;
    min-width: 0;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background: var(--surface-paper);
    padding: 1.1rem;
    box-shadow: var(--shadow-soft);
    transition:
      border-color var(--motion-duration) var(--ease-vrebo),
      box-shadow var(--motion-duration) var(--ease-vrebo),
      transform var(--motion-duration) var(--ease-vrebo);
  }

  .related-card:hover {
    border-color: rgb(101 17 19 / 0.28);
    box-shadow: var(--shadow-lift);
    transform: translateY(-2px);
  }

  .related-card > span {
    color: #2b090b;
    font-weight: 820;
  }

  .service-cta-shell {
    background: #fffaf4;
  }

  .service-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgb(101 17 19 / 0.9), rgb(21 17 15 / 0.98)),
      #15110f;
    padding: clamp(1.5rem, 5vw, 3.2rem);
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .service-cta .eyebrow,
  .service-cta h2 {
    color: #fffaf4;
  }

  .service-cta h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1;
  }

  .service-cta p {
    max-width: 42rem;
    margin: 1rem 0 0;
    color: rgb(255 250 244 / 0.74);
  }

  .service-cta__side {
    display: grid;
    flex: 0 0 min(22rem, 100%);
    gap: 1rem;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .related-links span,
  .related-links a {
    border: 1px solid rgb(255 250 244 / 0.16);
    border-radius: 999px;
    padding: 0.42rem 0.68rem;
    color: rgb(255 250 244 / 0.78);
    font-size: 0.86rem;
    font-weight: 720;
  }

  .related-links span {
    border-color: transparent;
    padding-left: 0;
  }

  @media (max-width: 820px) {
    .service-hero,
    .detail-grid,
    .related-section,
    .related-card-grid {
      grid-template-columns: 1fr;
    }

    .service-actions,
    .service-cta {
      align-items: stretch;
      flex-direction: column;
    }

    .service-media {
      aspect-ratio: 16 / 10;
      min-height: 16rem;
    }

    .service-media img {
      min-height: 16rem;
    }
  }
</style>
