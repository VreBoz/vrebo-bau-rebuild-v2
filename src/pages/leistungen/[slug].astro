---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { serviceNavigation } from '@/data/navigation';
import { breadcrumbSchema, serviceSchema, webPageSchema } from '@/utils/structuredData';

type Props = {
  service: CollectionEntry<'services'>;
};

export async function getStaticPaths() {
  const services = await getCollection('services');

  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const servicePath = `/leistungen/${service.data.slug}`;
const relatedLinks = service.data.relatedServices
  .map((slug) => serviceNavigation.find((item) => item.slug === slug))
  .filter((item): item is (typeof serviceNavigation)[number] => Boolean(item));
---

<BaseLayout
  title={service.data.seoTitle}
  description={service.data.seoDescription}
  image={service.data.heroImage?.src}
  imageAlt={service.data.heroImage?.alt}
  jsonLd={[
    webPageSchema({
      title: service.data.title,
      description: service.data.seoDescription,
      path: servicePath,
    }),
    serviceSchema(service.data),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Leistungen', path: '/leistungen' },
      { name: service.data.title, path: servicePath },
    ]),
  ]}
>
  <section class="section-shell">
    <div class="site-container service-hero">
      <div>
        <p class="eyebrow">Leistungsdetail</p>
        <h1 class="page-title">{service.data.title}</h1>
        <p class="lede">{service.data.intro}</p>
        <div class="tag-row" aria-label="Leistungs-Tags">
          {service.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <div class="service-actions">
          <Button href={`/kontakt?leistung=${service.data.slug}`} size="lg">Projekt anfragen</Button>
          <Button href="/leistungen" variant="secondary" size="lg">Alle Leistungen ansehen</Button>
        </div>
      </div>
      <div class:list={['surface', 'service-media', { 'skeleton-panel service-media--empty': !service.data.heroImage }]}>
        {service.data.heroImage ? (
          <img
            src={service.data.heroImage.src}
            alt={service.data.heroImage.alt}
            width={service.data.heroImage.width}
            height={service.data.heroImage.height}
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        ) : (
          <span>Bild wird nach passender Projektauswahl ergänzt</span>
        )}
      </div>
    </div>
  </section>

  <section class="section-shell detail-band">
    <div class="site-container detail-grid">
      <article class="surface detail-card">
        <p class="eyebrow">Leistungsumfang</p>
        <ul>
          {service.data.servicesIncluded.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article class="surface detail-card">
        <p class="eyebrow">Ablauf</p>
        <ol>
          {service.data.processSteps.map((step) => (
            <li>
              <strong>{step.title}</strong>
              <span>{step.description}</span>
            </li>
          ))}
        </ol>
      </article>
      {service.data.benefits.length > 0 && (
        <article class="surface detail-card detail-card--accent">
          <p class="eyebrow">Worauf wir achten</p>
          <ul>
            {service.data.benefits.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      )}
    </div>
  </section>

  <section class="section-shell">
    <div class="site-container--narrow prose-shell">
      <p class="eyebrow">Einordnung</p>
      <Content />
    </div>
  </section>

  <section class="section-shell--compact service-cta-shell">
    <div class="site-container service-cta">
      <div>
        <p class="eyebrow">Anfrage</p>
        <h2>{service.data.navLabel} besprechen</h2>
        <p>
          Beschreiben Sie kurz den Bestand, den gewünschten Umfang und den Ort. So lässt sich besser
          einschätzen, welche nächsten Schritte sinnvoll sind.
        </p>
      </div>
      <div class="service-cta__side">
        <Button href={`/kontakt?leistung=${service.data.slug}`} variant="dark" size="lg">Projekt schildern</Button>
        {relatedLinks.length > 0 && (
          <div class="related-links" aria-label="Verwandte Leistungen">
            <span>Passend dazu</span>
            {relatedLinks.map((item) => <a href={item.href}>{item.navLabel}</a>)}
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.72fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }

  .service-media {
    display: block;
    aspect-ratio: 4 / 3;
    min-height: 24rem;
    overflow: hidden;
    background: #e9dfd2;
    color: #6b625c;
    font-weight: 780;
  }

  .service-media img {
    width: 100%;
    height: 100%;
    min-height: 24rem;
    object-fit: cover;
    object-position: center;
  }

  .service-media--empty {
    display: grid;
    place-items: center;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .tag-row span {
    border: 1px solid rgb(101 17 19 / 0.16);
    border-radius: 999px;
    padding: 0.4rem 0.7rem;
    background: rgb(255 250 244 / 0.72);
    color: #651113;
    font-size: 0.86rem;
    font-weight: 760;
  }

  .service-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .detail-band {
    background: #f4efe8;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .detail-card {
    min-height: 100%;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .detail-card--accent {
    background: #fffaf4;
  }

  ul,
  ol {
    display: grid;
    gap: 0.75rem;
    margin: 1rem 0 0;
    padding-left: 1.2rem;
    color: #6b625c;
  }

  ol li span {
    display: block;
    margin-top: 0.15rem;
  }

  .prose-shell {
    color: #6b625c;
    font-size: 1.06rem;
  }

  .prose-shell :global(h2),
  .prose-shell :global(h3) {
    margin: 2rem 0 0.7rem;
    color: #2b090b;
    line-height: 1.15;
  }

  .prose-shell :global(p) {
    margin: 0 0 1rem;
  }

  .service-cta-shell {
    background: #fffaf4;
  }

  .service-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgb(101 17 19 / 0.9), rgb(21 17 15 / 0.98)),
      #15110f;
    padding: clamp(1.5rem, 5vw, 3.2rem);
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .service-cta .eyebrow,
  .service-cta h2 {
    color: #fffaf4;
  }

  .service-cta h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1;
  }

  .service-cta p {
    max-width: 42rem;
    margin: 1rem 0 0;
    color: rgb(255 250 244 / 0.74);
  }

  .service-cta__side {
    display: grid;
    flex: 0 0 min(22rem, 100%);
    gap: 1rem;
  }

  .related-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .related-links span,
  .related-links a {
    border: 1px solid rgb(255 250 244 / 0.16);
    border-radius: 999px;
    padding: 0.42rem 0.68rem;
    color: rgb(255 250 244 / 0.78);
    font-size: 0.86rem;
    font-weight: 720;
  }

  .related-links span {
    border-color: transparent;
    padding-left: 0;
  }

  @media (max-width: 820px) {
    .service-hero,
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .service-actions,
    .service-cta {
      align-items: stretch;
      flex-direction: column;
    }

    .service-media {
      aspect-ratio: 16 / 10;
      min-height: 16rem;
    }

    .service-media img {
      min-height: 16rem;
    }
  }
</style>
