---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Impressum';
const description = 'Arbeitsversion des Impressums fuer die neue Vrebo Bau Website.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    webPageSchema({ title, description, path: '/impressum' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Impressum', path: '/impressum' },
    ]),
  ]}
>
  <section class="section-shell">
    <article class="site-container--narrow legal-shell">
      <p class="eyebrow">Rechtliches</p>
      <h1>Impressum</h1>
      <p>Die Anbieterkennzeichnung wird vor dem Launch geprueft und eingesetzt.</p>
    </article>
  </section>
</BaseLayout>

<style>
  .legal-shell {
    color: #6b625c;
    font-size: 1.05rem;
  }

  h1 {
    margin: 0 0 1rem;
    color: #15110f;
    font-size: 2.4rem;
    letter-spacing: 0;
    line-height: 1;
  }

  @media (min-width: 760px) {
    h1 {
      font-size: 4rem;
    }
  }
</style>
