---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/ui/Button.astro';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Seite nicht gefunden';
const description = 'Die gesuchte Seite wurde nicht gefunden. Von hier aus gelangen Sie zurück zu Vrebo Bau, den Leistungen oder zur Kontaktseite.';
---

<BaseLayout
  title={title}
  description={description}
  noindex
  jsonLd={[
    webPageSchema({ title, description, path: '/404' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: '404', path: '/404' },
    ]),
  ]}
>
  <section class="section-shell not-found">
    <div class="site-container not-found__grid">
      <div>
        <p class="eyebrow">404</p>
        <h1 class="page-title">Diese Seite wurde nicht gefunden</h1>
        <p class="lede">
          Vielleicht wurde eine alte Adresse aufgerufen oder ein Link hat sich geändert. Die
          wichtigsten Bereiche sind weiterhin direkt erreichbar.
        </p>
        <div class="not-found__actions">
          <Button href="/" size="lg">Zur Startseite</Button>
          <Button href="/leistungen" variant="secondary" size="lg">Leistungen ansehen</Button>
          <Button href="/kontakt" variant="secondary" size="lg">Kontakt öffnen</Button>
        </div>
      </div>
      <div class="surface not-found__panel">
        <span>Vrebo Bau</span>
        <p>Renovierung, Sanierung und Ausbau in Freilassing und Umgebung.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    background: #fffaf4;
  }

  .not-found__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.48fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .not-found__panel {
    display: grid;
    min-height: 18rem;
    align-content: end;
    padding: clamp(1.4rem, 4vw, 2.2rem);
    background:
      linear-gradient(145deg, rgb(101 17 19 / 0.88), rgb(21 17 15 / 0.95)),
      #15110f;
    color: #fffaf4;
  }

  .not-found__panel span {
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 840;
    line-height: 1;
  }

  .not-found__panel p {
    max-width: 20rem;
    margin: 1rem 0 0;
    color: rgb(255 250 244 / 0.74);
  }

  @media (max-width: 820px) {
    .not-found__grid {
      grid-template-columns: 1fr;
    }

    .not-found__actions {
      flex-direction: column;
    }
  }
</style>
