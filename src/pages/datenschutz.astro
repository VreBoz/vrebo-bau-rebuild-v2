---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Datenschutz';
const description = 'Technischer Seiten-Skeleton fuer die Datenschutzseite von Vrebo Bau.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    webPageSchema({ title, description, path: '/datenschutz' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Datenschutz', path: '/datenschutz' },
    ]),
  ]}
>
  <section class="section-shell">
    <article class="site-container--narrow legal-shell">
      <p class="eyebrow">Legal Skeleton</p>
      <h1>Datenschutz</h1>
      <p>Die finale rechtliche Fassung wird in einer spaeteren Phase geprueft und eingesetzt.</p>
    </article>
  </section>
</BaseLayout>

<style>
  .legal-shell {
    color: #6b625c;
    font-size: 1.05rem;
  }

  h1 {
    margin: 0 0 1rem;
    color: #15110f;
    font-size: clamp(2.4rem, 6vw, 4.4rem);
    letter-spacing: 0;
    line-height: 1;
  }
</style>
