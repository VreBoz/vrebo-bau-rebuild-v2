---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/sections/PageHero.astro';
import FinalCTA from '@/components/sections/FinalCTA.astro';
import { servicesOverviewImage } from '@/data/assets';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Über Vrebo Bau in Freilassing';
const description = 'Vrebo Bau steht für regionale Nähe, saubere Arbeitsweise und direkte Abstimmung bei Bau- und Sanierungsprojekten in Freilassing.';
const values = [
  {
    title: 'Lokale Nähe',
    text: 'Der Schwerpunkt liegt auf Freilassing, Bad Reichenhall und dem Berchtesgadener Land.',
  },
  {
    title: 'Saubere Arbeitsweise',
    text: 'Bestand, Schutzmaßnahmen und Übergaben werden vor Beginn klar mitgedacht.',
  },
  {
    title: 'Direkte Abstimmung',
    text: 'Kurze Wege helfen, Umfang, Reihenfolge und nächste Schritte verständlich zu halten.',
  },
  {
    title: 'Vertrauen',
    text: 'Keine erfundenen Kennzahlen, sondern ein ruhiger Auftritt mit nachvollziehbaren Leistungen.',
  },
];
const pageActions = [
  { label: 'Projekt anfragen', href: '/kontakt', variant: 'primary' },
  { label: 'Leistungen ansehen', href: '/leistungen', variant: 'secondary' },
] as const;
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    webPageSchema({ title, description, path: '/ueber-uns', type: 'AboutPage' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Über uns', path: '/ueber-uns' },
    ]),
  ]}
  image={servicesOverviewImage.src}
  imageAlt={servicesOverviewImage.alt}
>
  <PageHero
    eyebrow="Unternehmen"
    title="Über Vrebo Bau"
    description="Vrebo Bau steht für Bau- und Sanierungsarbeiten mit regionalem Bezug, klarer Abstimmung und einem ordentlichen Umgang mit dem Bestand."
    tags={['Freilassing', 'Saubere Ausführung', 'Direkte Abstimmung']}
    actions={pageActions}
    image={servicesOverviewImage}
  />

  <section class="section-shell about-band">
    <div class="site-container about-values">
      <div class="about-intro">
        <p class="eyebrow">Arbeitsweise</p>
        <h2>Ruhig planen, sauber arbeiten, direkt abstimmen</h2>
        <p>
          Die Über-uns-Seite bleibt bewusst ohne unbestätigte Zahlen oder große Versprechen. Im
          Mittelpunkt stehen Nähe, Ordnung und eine klare Kommunikation während des Projekts.
        </p>
        <div class="about-mark" aria-hidden="true">
          <img
            src="/images/brand/vrebo-wordmark.png"
            alt=""
            width="720"
            height="214"
            loading="lazy"
            decoding="async"
          />
          <span>Handwerklich sauber. Regional nah.</span>
        </div>
      </div>
      <div class="value-grid">
        {values.map((item) => (
          <article class="surface value-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA
    title="Projekt mit Vrebo Bau besprechen"
    description="Eine kurze Beschreibung des Vorhabens reicht für den ersten Schritt. Umfang, Ort und nächste Abstimmung können danach persönlich geklärt werden."
  />
</BaseLayout>

<style>
  .about-band {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(118deg, transparent 0 64%, rgb(101 17 19 / 0.04) 64% 82%, transparent 82%),
      linear-gradient(180deg, rgb(244 239 232 / 0.96), rgb(233 223 210 / 0.74)),
      #f4efe8;
  }

  .about-band::after {
    position: absolute;
    right: -9rem;
    bottom: -9rem;
    width: min(42rem, 84vw);
    height: 21rem;
    pointer-events: none;
    background-image: var(--brand-silhouette);
    background-position: right bottom;
    background-repeat: no-repeat;
    background-size: contain;
    content: "";
    opacity: 0.07;
  }

  .about-values {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.74fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .about-intro h2 {
    margin: 0;
    color: #2b090b;
    font-size: clamp(2rem, 5vw, 3.25rem);
    line-height: 1.04;
  }

  .about-intro p {
    margin: 1rem 0 0;
    color: #6b625c;
    line-height: 1.68;
  }

  .about-mark {
    position: relative;
    overflow: hidden;
    margin-top: 1.35rem;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgb(255 250 244 / 0.86), rgb(255 250 244 / 0.58)),
      #fffaf4;
    padding: 1rem;
    box-shadow: var(--shadow-soft);
  }

  .about-mark::after {
    position: absolute;
    right: -1.5rem;
    bottom: -3rem;
    width: 18rem;
    height: 9rem;
    background-image: var(--brand-silhouette);
    background-position: right bottom;
    background-repeat: no-repeat;
    background-size: contain;
    content: "";
    opacity: 0.16;
  }

  .about-mark img {
    position: relative;
    z-index: 1;
    width: 6.8rem;
    height: auto;
  }

  .about-mark span {
    position: relative;
    z-index: 1;
    display: block;
    margin-top: 0.8rem;
    color: #302b28;
    font-weight: 780;
  }

  .value-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .value-card {
    position: relative;
    overflow: hidden;
    padding: clamp(1.1rem, 3vw, 1.6rem);
  }

  .value-card::before {
    display: block;
    width: 2rem;
    height: 1px;
    margin-bottom: 1rem;
    background: #ab3743;
    content: "";
  }

  .value-card h3 {
    margin: 0;
    color: #2b090b;
    font-size: 1.12rem;
  }

  .value-card p {
    margin: 0.55rem 0 0;
    color: #6b625c;
    line-height: 1.62;
  }

  @media (max-width: 820px) {
    .about-values,
    .value-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
