---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Ueber uns';
const description = 'Arbeitsversion der Ueber-uns-Seite fuer die neue Vrebo Bau Website.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    webPageSchema({ title, description, path: '/ueber-uns', type: 'AboutPage' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Ueber uns', path: '/ueber-uns' },
    ]),
  ]}
>
  <section class="section-shell">
    <div class="site-container page-grid">
      <div>
        <p class="eyebrow">Unternehmen</p>
        <h1 class="page-title">Ueber uns</h1>
        <p class="lede">Struktur fuer Story, Arbeitsweise, Werte und regionale Verankerung.</p>
      </div>
      <div class="surface skeleton-panel">Bild- oder Arbeitsweise-Modul</div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.55fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }

  .skeleton-panel {
    display: grid;
    min-height: 20rem;
    place-items: center;
    color: #6b625c;
    font-weight: 780;
  }

  @media (max-width: 820px) {
    .page-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
