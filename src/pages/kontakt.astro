---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Kontakt';
const description = 'Technischer Seiten-Skeleton fuer die Kontaktseite von Vrebo Bau.';
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    webPageSchema({ title, description, path: '/kontakt', type: 'ContactPage' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Kontakt', path: '/kontakt' },
    ]),
  ]}
>
  <section class="section-shell">
    <div class="site-container contact-grid">
      <div>
        <p class="eyebrow">Phase 2 Skeleton</p>
        <h1 class="page-title">Kontakt</h1>
        <p class="lede">Basis fuer Kontaktinformationen, Anfrageformular und Einsatzgebiet.</p>
      </div>
      <form class="surface contact-form" aria-label="Kontaktformular Skeleton">
        <label>
          Name
          <input type="text" name="name" autocomplete="name" disabled />
        </label>
        <label>
          E-Mail
          <input type="email" name="email" autocomplete="email" disabled />
        </label>
        <label>
          Nachricht
          <textarea name="message" rows="4" disabled></textarea>
        </label>
        <button class="button button--primary" type="button" disabled>Formular folgt</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(18rem, 0.6fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .contact-form {
    display: grid;
    gap: 1rem;
    padding: clamp(1.2rem, 3vw, 2rem);
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: #302b28;
    font-weight: 760;
  }

  input,
  textarea {
    width: 100%;
    border: 1px solid rgb(48 43 40 / 0.16);
    border-radius: var(--radius-sm);
    background: #fffaf4;
    padding: 0.78rem 0.85rem;
    color: #6b625c;
  }

  button:disabled,
  input:disabled,
  textarea:disabled {
    cursor: not-allowed;
    opacity: 0.72;
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
