---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/sections/PageHero.astro';
import ContactForm from '@/components/sections/ContactForm.astro';
import { homeHeroImage } from '@/data/assets';
import { breadcrumbSchema, webPageSchema } from '@/utils/structuredData';

const title = 'Kontakt zu Vrebo Bau in Freilassing';
const description = 'Kontakt für Renovierung, Sanierung, Badsanierung und Ausbau mit Vrebo Bau in Freilassing, Bad Reichenhall und Umgebung.';
const pageActions = [
  { label: 'Zum Formular', href: '#anfrage', variant: 'primary' },
  { label: 'Leistungen ansehen', href: '/leistungen', variant: 'secondary' },
] as const;
---

<BaseLayout
  title={title}
  description={description}
  jsonLd={[
    webPageSchema({ title, description, path: '/kontakt', type: 'ContactPage' }),
    breadcrumbSchema([
      { name: 'Startseite', path: '/' },
      { name: 'Kontakt', path: '/kontakt' },
    ]),
  ]}
  image={homeHeroImage.src}
  imageAlt={homeHeroImage.alt}
>
  <PageHero
    eyebrow="Kontakt"
    title="Projekt kurz schildern"
    description="Ob Bad, Boden, Innenausbau, Objektpflege oder Renovierung: Für den ersten Kontakt reichen wenige Eckdaten. Je klarer Ort, Umfang und gewünschter Zeitraum beschrieben sind, desto besser lässt sich der nächste Schritt einordnen."
    tags={['Freilassing', 'Bad Reichenhall', 'Berchtesgadener Land']}
    actions={pageActions}
    mediaLabel="Kontakt und Anfrage"
    image={homeHeroImage}
  />

  <section class="section-shell contact-section">
    <div class="site-container contact-grid">
      <aside class="contact-aside" aria-label="Hinweise zur Kontaktaufnahme">
        <div class="surface contact-panel">
          <p class="eyebrow">Hilfreich für die Anfrage</p>
          <h2>Was direkt weiterhilft</h2>
          <p>
            Eine kurze Beschreibung reicht für den Start. Fotos vom Bestand, Maße oder Hinweise zur
            Nutzung helfen, den Umfang besser einzuschätzen.
          </p>
          <ul>
            <li>Ort des Projekts oder Objekts</li>
            <li>Leistungsbereich, zum Beispiel Bad, Boden, Trockenbau oder Objektpflege</li>
            <li>Grobe Größe, Zustand und gewünschter Zeitraum</li>
            <li>Fotos oder Skizzen, falls vorhanden</li>
          </ul>
        </div>

        <div class="surface contact-panel contact-panel--quiet">
          <p class="eyebrow">Nächster Schritt</p>
          <h2>Persönliche Einordnung statt langem Formular</h2>
          <p>
            Nach der ersten Nachricht kann geklärt werden, ob ein kurzer Rückruf, eine Besichtigung
            oder zunächst weitere Unterlagen sinnvoll sind.
          </p>
        </div>
        <div class="contact-brand-card" aria-label="Regionale Einordnung">
          <img
            src="/images/brand/vrebo-wordmark.png"
            alt=""
            width="720"
            height="214"
            loading="lazy"
            decoding="async"
          />
          <p>Freilassing, Bad Reichenhall und Berchtesgadener Land.</p>
        </div>
      </aside>

      <ContactForm />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-section {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(118deg, transparent 0 68%, rgb(101 17 19 / 0.04) 68% 82%, transparent 82%),
      linear-gradient(180deg, rgb(244 239 232 / 0.96), rgb(233 223 210 / 0.72)),
      #f4efe8;
  }

  .contact-section::after {
    position: absolute;
    left: -10rem;
    bottom: -8rem;
    width: min(42rem, 86vw);
    height: 20rem;
    pointer-events: none;
    background-image: var(--brand-silhouette);
    background-position: left bottom;
    background-repeat: no-repeat;
    background-size: contain;
    content: "";
    opacity: 0.07;
  }

  .contact-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(20rem, 0.78fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .contact-aside {
    display: grid;
    gap: 1.05rem;
  }

  .contact-panel {
    position: relative;
    overflow: hidden;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .contact-panel::after {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.24rem;
    background: linear-gradient(180deg, #ab3743, rgb(101 17 19 / 0.16));
    content: "";
  }

  .contact-panel--quiet {
    background: rgb(255 250 244 / 0.78);
    box-shadow: none;
  }

  .contact-brand-card {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgb(21 17 15 / 0.98), rgb(43 9 11 / 0.95)),
      #15110f;
    padding: 1.15rem;
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .contact-brand-card::after {
    position: absolute;
    inset: auto -2rem -4rem 18%;
    height: 11rem;
    background-image: var(--brand-silhouette);
    background-position: center bottom;
    background-repeat: no-repeat;
    background-size: contain;
    content: "";
    opacity: 0.18;
    mix-blend-mode: screen;
  }

  .contact-brand-card img {
    width: 6.9rem;
    height: auto;
    border-radius: var(--radius-sm);
    background: #fffaf4;
    padding: 0.42rem 0.54rem;
  }

  .contact-brand-card p {
    position: relative;
    z-index: 1;
    max-width: 18rem;
    margin: 1rem 0 0;
    color: rgb(255 250 244 / 0.76);
    font-weight: 720;
    line-height: 1.55;
  }

  .contact-panel h2 {
    margin: 0;
    color: #2b090b;
    font-size: clamp(1.45rem, 2.7vw, 1.95rem);
    line-height: 1.08;
  }

  .contact-panel p {
    margin: 0.9rem 0 0;
    color: #6b625c;
    line-height: 1.66;
  }

  .contact-panel ul {
    display: grid;
    gap: 0.65rem;
    margin: 1.4rem 0 0;
    padding-left: 1.1rem;
    color: #302b28;
    line-height: 1.58;
  }

  @media (max-width: 820px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
