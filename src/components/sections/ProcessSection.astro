---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { processSteps, type ProcessStep } from '@/data/sections';

interface Props {
  steps?: ProcessStep[];
  band?: boolean;
  home?: boolean;
}

const { steps = processSteps, band = false, home = false } = Astro.props;
---

<section class:list={['process-section', 'section-shell', { 'section-band': band, 'process-section--home': home }]}>
  <div class="site-container">
    {home ? (
      <div class="process-section__home-grid">
        <div>
          <SectionHeading
            eyebrow="Arbeitsweise"
            title="Ein Ablauf, der Bauentscheidungen leichter macht"
            description="Die Schritte sind bewusst schlank gehalten. Erst wird eingeordnet, dann abgestimmt, dann sauber umgesetzt."
          />
          <div class="process-section__note">
            <strong>Kein unnötiger Aufwand vorab.</strong>
            <p>Für den ersten Kontakt reichen eine kurze Beschreibung, Ort, Umfang und falls vorhanden ein paar Fotos.</p>
          </div>
        </div>

        <ol class="process-section__timeline">
          {steps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    ) : (
      <>
        <SectionHeading
          eyebrow="Arbeitsweise"
          title="Vom ersten Kontakt zur geordneten Ausführung"
          description="Der Ablauf bleibt verständlich: erst einordnen, dann vor Ort abstimmen, anschließend die nächsten Schritte sauber planen."
        />
        <ol class="process-section__list">
          {steps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </li>
          ))}
        </ol>
      </>
    )}
  </div>
</section>

<style>
  .process-section--home {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(180deg, #fffaf4 0%, rgb(244 239 232 / 0.58) 100%),
      #fffaf4;
  }

  .process-section--home::before {
    position: absolute;
    inset: clamp(1.25rem, 4vw, 3rem) 0 auto;
    height: 1px;
    pointer-events: none;
    background: linear-gradient(90deg, transparent, rgb(101 17 19 / 0.16), transparent);
    content: "";
  }

  .process-section__home-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(0, 1.14fr);
    gap: clamp(2rem, 6vw, 5.5rem);
    align-items: start;
  }

  .process-section--home :global(.section-heading h2) {
    max-width: 13ch;
    font-size: clamp(2.45rem, 4.7vw, 3.35rem);
    overflow-wrap: normal;
  }

  .process-section__note {
    position: relative;
    max-width: 31rem;
    margin-top: clamp(1.8rem, 4vw, 2.8rem);
    border-top: 1px solid rgb(48 43 40 / 0.13);
    padding: clamp(1.15rem, 3vw, 1.45rem) 0 0 clamp(1.05rem, 2.5vw, 1.35rem);
  }

  .process-section__note::before {
    position: absolute;
    top: clamp(1.15rem, 3vw, 1.45rem);
    left: 0;
    width: 0.24rem;
    height: calc(100% - clamp(1.15rem, 3vw, 1.45rem));
    min-height: 4.6rem;
    background: linear-gradient(180deg, #ab3743, rgb(101 17 19 / 0.18));
    content: "";
  }

  .process-section__note strong {
    display: block;
    color: #2b090b;
    font-size: 1.02rem;
  }

  .process-section__note p {
    margin: 0.4rem 0 0;
  }

  .process-section__timeline {
    position: relative;
    display: grid;
    gap: 0;
    margin: 0;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(145deg, rgb(255 255 255 / 0.46), transparent 44%),
      rgb(255 250 244 / 0.78);
    padding: clamp(0.55rem, 1.4vw, 0.8rem);
    list-style: none;
    box-shadow: var(--shadow-card);
  }

  .process-section__timeline::before {
    position: absolute;
    top: clamp(2.4rem, 4vw, 3rem);
    bottom: clamp(2.4rem, 4vw, 3rem);
    left: clamp(2rem, 4vw, 2.55rem);
    width: 1px;
    background: linear-gradient(180deg, rgb(171 55 67 / 0.1), rgb(171 55 67 / 0.5), rgb(171 55 67 / 0.1));
    content: "";
  }

  .process-section__timeline li {
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(1rem, 2.4vw, 1.35rem);
    align-items: start;
    border: 0;
    border-radius: var(--radius-lg);
    background: transparent;
    padding: clamp(1.15rem, 2.6vw, 1.65rem);
    box-shadow: none;
  }

  .process-section__timeline li + li {
    border-top: 1px solid rgb(48 43 40 / 0.09);
  }

  .process-section__timeline span {
    position: relative;
    z-index: 1;
    background: #fffaf4;
    box-shadow: 0 0 0 0.45rem #fffaf4;
  }

  .process-section__timeline h3 {
    margin: 0;
    font-size: clamp(1.12rem, 1.7vw, 1.28rem);
  }

  .process-section__list {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.9rem, 2vw, 1.2rem);
    margin: clamp(1.5rem, 3vw, 2.2rem) 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    min-width: 0;
    min-height: 100%;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background: var(--surface-paper);
    padding: clamp(1.15rem, 2.5vw, 1.45rem);
    box-shadow: var(--shadow-soft);
  }

  span {
    display: inline-flex;
    min-width: 2.45rem;
    min-height: 2.45rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(101 17 19 / 0.16);
    border-radius: 999px;
    background: rgb(101 17 19 / 0.06);
    color: #ab3743;
    font-size: 0.86rem;
    font-weight: 820;
  }

  h3 {
    margin: 1rem 0 0;
    color: #2b090b;
    font-size: 1.15rem;
    font-weight: 820;
    letter-spacing: 0;
  }

  p {
    margin: 0.45rem 0 0;
    color: #6b625c;
    line-height: 1.62;
  }

  @media (max-width: 980px) {
    .process-section__home-grid {
      grid-template-columns: 1fr;
      gap: clamp(1.6rem, 5vw, 2.6rem);
    }

    .process-section__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 580px) {
    .process-section__list {
      grid-template-columns: 1fr;
    }

    .process-section--home :global(.section-heading h2) {
      max-width: 100%;
      font-size: 1.72rem;
      overflow-wrap: anywhere;
    }

    .process-section__timeline {
      border-radius: var(--radius-lg);
    }

    .process-section__timeline::before {
      left: 2.05rem;
    }

    .process-section__timeline li {
      gap: 0.85rem;
      padding: 1rem 0.9rem;
    }
  }
</style>
