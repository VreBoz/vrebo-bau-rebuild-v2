---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { processSteps, type ProcessStep } from '@/data/sections';

interface Props {
  steps?: ProcessStep[];
  band?: boolean;
  home?: boolean;
}

const { steps = processSteps, band = false, home = false } = Astro.props;
---

<section class:list={['process-section', 'section-shell', { 'section-band': band, 'process-section--home': home }]}>
  <div class="site-container">
    {home ? (
      <div class="process-section__home-grid">
        <div>
          <SectionHeading
            eyebrow="Arbeitsweise"
            title="Ein Ablauf, der Bauentscheidungen leichter macht"
            description="Die Schritte sind bewusst schlank gehalten. Erst wird eingeordnet, dann abgestimmt, dann sauber umgesetzt."
          />
          <div class="process-section__note">
            <strong>Kein unnötiger Aufwand vorab.</strong>
            <p>Für den ersten Kontakt reichen eine kurze Beschreibung, Ort, Umfang und falls vorhanden ein paar Fotos.</p>
          </div>
        </div>

        <ol class="process-section__timeline">
          {steps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    ) : (
      <>
        <SectionHeading
          eyebrow="Arbeitsweise"
          title="Vom ersten Kontakt zur geordneten Ausführung"
          description="Der Ablauf bleibt verständlich: erst einordnen, dann vor Ort abstimmen, anschließend die nächsten Schritte sauber planen."
        />
        <ol class="process-section__list">
          {steps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </li>
          ))}
        </ol>
      </>
    )}
  </div>
</section>

<style>
  .process-section--home {
    background:
      linear-gradient(180deg, #fffaf4 0%, rgb(244 239 232 / 0.58) 100%),
      #fffaf4;
  }

  .process-section__home-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }

  .process-section--home :global(.section-heading h2) {
    font-size: clamp(2.35rem, 4.5vw, 3.05rem);
    overflow-wrap: normal;
  }

  .process-section__note {
    margin-top: clamp(1.4rem, 3vw, 2.2rem);
    border-left: 0.28rem solid #ab3743;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: rgb(255 250 244 / 0.86);
    padding: 1.15rem 1.25rem;
    box-shadow: 0 18px 44px rgb(21 17 15 / 0.055);
  }

  .process-section__note strong {
    display: block;
    color: #2b090b;
    font-size: 1.02rem;
  }

  .process-section__note p {
    margin: 0.4rem 0 0;
  }

  .process-section__timeline {
    position: relative;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .process-section__timeline::before {
    content: none;
  }

  .process-section__timeline li {
    position: relative;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 1rem;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgb(255 255 255 / 0.5), transparent 44%),
      var(--surface-paper);
    padding: clamp(1.05rem, 2vw, 1.35rem);
    box-shadow: var(--shadow-soft);
  }

  .process-section__timeline span {
    background: #fffaf4;
  }

  .process-section__timeline h3 {
    margin-top: 0;
  }

  .process-section__list {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(0.9rem, 2vw, 1.2rem);
    margin: clamp(1.5rem, 3vw, 2.2rem) 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    min-width: 0;
    min-height: 100%;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background: var(--surface-paper);
    padding: clamp(1.15rem, 2.5vw, 1.45rem);
    box-shadow: var(--shadow-soft);
  }

  span {
    display: inline-flex;
    min-width: 2.45rem;
    min-height: 2.45rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(101 17 19 / 0.16);
    border-radius: 999px;
    background: rgb(101 17 19 / 0.06);
    color: #ab3743;
    font-size: 0.86rem;
    font-weight: 820;
  }

  h3 {
    margin: 1rem 0 0;
    color: #2b090b;
    font-size: 1.15rem;
    font-weight: 820;
    letter-spacing: 0;
  }

  p {
    margin: 0.45rem 0 0;
    color: #6b625c;
    line-height: 1.62;
  }

  @media (max-width: 980px) {
    .process-section__home-grid {
      grid-template-columns: 1fr;
    }

    .process-section__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 580px) {
    .process-section__timeline,
    .process-section__list {
      grid-template-columns: 1fr;
    }
  }
</style>
