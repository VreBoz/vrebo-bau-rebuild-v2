---
import Button from '@/components/ui/Button.astro';
import Tag from '@/components/ui/Tag.astro';
import type { ImageAsset } from '@/data/assets';

interface Props {
  title?: string;
  description?: string;
  image?: ImageAsset;
}

const {
  title = 'Bauunternehmen für Renovierung, Sanierung und Ausbau in Freilassing',
  description = 'Vrebo Bau begleitet private und gewerbliche Projekte in der Region mit klarer Abstimmung, sauberer Ausführung und einem realistischen Blick auf den Ablauf.',
  image,
} = Astro.props;
---

<section class="hero-home">
  <div class="site-container--wide hero-home__frame">
    <div class="hero-home__copy">
      <Tag variant="dark">Vrebo Bau Freilassing</Tag>
      <h1>{title}</h1>
      <p>{description}</p>
      <div class="hero-home__actions" aria-label="Primäre Aktionen">
        <Button href="/kontakt" variant="dark" size="lg">Projekt anfragen</Button>
        <Button href="/leistungen" variant="ghost" size="lg">Leistungen ansehen</Button>
      </div>
      <ul class="hero-home__trust" aria-label="Vertrauenssignale">
        <li>Direkter Ansprechpartner</li>
        <li>Saubere Ausführung</li>
        <li>Region Freilassing</li>
      </ul>
    </div>

    <div class:list={['hero-home__media', { 'hero-home__media--empty': !image }]}>
      {image ? (
        <img
          src={image.src}
          alt={image.alt}
          width={image.width}
          height={image.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <span>Projektmotiv</span>
      )}
    </div>
  </div>
</section>

<style>
  .hero-home {
    padding: clamp(1rem, 2vw, 1.5rem) 0 var(--section-y-compact);
    background: #fffaf4;
  }

  .hero-home__frame {
    display: grid;
    min-height: 34rem;
    grid-template-columns: minmax(0, 0.92fr) minmax(18rem, 0.78fr);
    gap: clamp(1.25rem, 3vw, 2rem);
    overflow: hidden;
    border-radius: var(--radius-xl);
    background: #15110f;
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .hero-home__copy {
    display: grid;
    align-content: center;
    min-width: 0;
    padding: clamp(1.5rem, 5vw, 4.5rem);
  }

  h1 {
    max-width: 48rem;
    margin: 1.1rem 0 0;
    color: #fffaf4;
    font-size: 2.55rem;
    font-weight: 840;
    letter-spacing: 0;
    line-height: 1;
  }

  p {
    max-width: 39rem;
    margin: 1.25rem 0 0;
    color: rgb(255 250 244 / 0.76);
    font-size: 1.08rem;
  }

  .hero-home__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-home__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1rem;
    margin: 2rem 0 0;
    padding: 0;
    color: rgb(255 250 244 / 0.72);
    font-size: 0.94rem;
    list-style: none;
  }

  .hero-home__trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .hero-home__trust li::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: #ab3743;
  }

  .hero-home__media {
    position: relative;
    display: block;
    height: 100%;
    min-height: 100%;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgb(21 17 15 / 0.05), rgb(21 17 15 / 0.78)),
      linear-gradient(145deg, #d6c6b4, #ab3743 62%, #651113);
  }

  .hero-home__media::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    content: "";
    background: linear-gradient(180deg, rgb(21 17 15 / 0.02), rgb(21 17 15 / 0.34));
  }

  .hero-home__media img {
    width: 100%;
    height: 100%;
    min-height: 100%;
    object-fit: cover;
    object-position: 52% 50%;
  }

  .hero-home__media--empty {
    display: grid;
    place-items: end start;
    padding: 1.3rem;
  }

  .hero-home__media--empty::after {
    display: none;
  }

  .hero-home__media--empty span {
    border: 1px solid rgb(255 250 244 / 0.18);
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    background: rgb(21 17 15 / 0.34);
    color: rgb(255 250 244 / 0.78);
    font-size: 0.9rem;
    font-weight: 760;
  }

  @media (min-width: 760px) {
    h1 {
      font-size: 3.45rem;
    }

    p {
      font-size: 1.14rem;
    }
  }

  @media (min-width: 1180px) {
    h1 {
      font-size: 4.45rem;
    }
  }

  @media (max-width: 860px) {
    .hero-home__frame {
      min-height: auto;
      grid-template-columns: 1fr;
    }

    .hero-home__media {
      min-height: 13rem;
    }

    .hero-home__media img {
      min-height: 13rem;
    }
  }

  @media (max-width: 520px) {
    .hero-home__actions {
      flex-direction: column;
    }
  }
</style>
