---
import Button from '@/components/ui/Button.astro';
import Tag from '@/components/ui/Tag.astro';
import type { ImageAsset } from '@/data/assets';

interface Props {
  title?: string;
  description?: string;
  image?: ImageAsset;
}

const {
  title = 'Bauunternehmen für Renovierung, Sanierung und Ausbau in Freilassing',
  description = 'Vrebo Bau begleitet private und gewerbliche Projekte in der Region mit klarer Abstimmung, sauberer Ausführung und einem realistischen Blick auf den Ablauf.',
  image,
} = Astro.props;
---

<section class="hero-home">
  <div class="site-container--wide hero-home__frame">
    <div class="hero-home__copy">
      <Tag variant="dark">Vrebo Bau Freilassing</Tag>
      <h1>{title}</h1>
      <p>{description}</p>
      <div class="hero-home__actions" aria-label="Primäre Aktionen">
        <Button href="/kontakt" variant="dark" size="lg">Projekt anfragen</Button>
        <Button href="/leistungen" variant="ghost" size="lg">Leistungen ansehen</Button>
      </div>
      <ul class="hero-home__trust" aria-label="Vertrauenssignale">
        <li>Direkter Ansprechpartner</li>
        <li>Saubere Ausführung</li>
        <li>Region Freilassing</li>
      </ul>
    </div>

    <div class:list={['hero-home__media', { 'hero-home__media--empty': !image }]}>
      {image ? (
        <img
          src={image.src}
          alt={image.alt}
          width={image.width}
          height={image.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <span>Projektmotiv</span>
      )}
    </div>
  </div>
</section>

<style>
  .hero-home {
    padding: clamp(1rem, 2vw, 1.45rem) 0 clamp(2.25rem, 5vw, 4rem);
    background:
      linear-gradient(180deg, rgb(255 250 244 / 0.92), rgb(244 239 232 / 0.28) 82%, transparent),
      #fffaf4;
  }

  .hero-home__frame {
    position: relative;
    display: grid;
    min-height: clamp(31rem, 50vw, 37rem);
    grid-template-columns: minmax(0, 0.95fr) minmax(19rem, 0.82fr);
    gap: clamp(1rem, 2.8vw, 2rem);
    overflow: hidden;
    border-radius: var(--radius-xl);
    border: 1px solid rgb(255 250 244 / 0.1);
    background:
      linear-gradient(135deg, #15110f 0%, #211b18 52%, #2b090b 100%),
      #15110f;
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .hero-home__frame::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgb(255 250 244 / 0.055) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 250 244 / 0.04) 1px, transparent 1px);
    background-size: 5.5rem 5.5rem;
    content: "";
    mask-image: linear-gradient(90deg, black, transparent 62%);
  }

  .hero-home__copy {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: center;
    min-width: 0;
    padding: clamp(1.65rem, 4.6vw, 4rem);
  }

  h1 {
    max-width: 48rem;
    margin: 1.18rem 0 0;
    color: #fffaf4;
    font-size: 2.55rem;
    font-weight: 850;
    letter-spacing: 0;
    line-height: 0.99;
  }

  p {
    max-width: 39rem;
    margin: 1.35rem 0 0;
    color: rgb(255 250 244 / 0.78);
    font-size: 1.08rem;
    line-height: 1.68;
  }

  .hero-home__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-home__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 2.15rem 0 0;
    padding: 0;
    color: rgb(255 250 244 / 0.8);
    font-size: 0.94rem;
    list-style: none;
  }

  .hero-home__trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border: 1px solid rgb(255 250 244 / 0.13);
    border-radius: 999px;
    padding: 0.48rem 0.7rem;
    background: rgb(255 250 244 / 0.07);
  }

  .hero-home__trust li::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 999px;
    background: #ab3743;
  }

  .hero-home__media {
    position: relative;
    display: block;
    height: 100%;
    min-height: 100%;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgb(21 17 15 / 0.02), rgb(21 17 15 / 0.72)),
      linear-gradient(145deg, #d6c6b4, #ab3743 62%, #651113);
  }

  .hero-home__media::before {
    position: absolute;
    inset: 0 auto 0 0;
    z-index: 1;
    width: 34%;
    pointer-events: none;
    background: linear-gradient(90deg, #15110f, rgb(21 17 15 / 0));
    content: "";
  }

  .hero-home__media::after {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    content: "";
    background:
      linear-gradient(180deg, rgb(21 17 15 / 0.02), rgb(21 17 15 / 0.28)),
      linear-gradient(90deg, rgb(21 17 15 / 0.04), transparent 30%);
  }

  .hero-home__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-height: 100%;
    object-fit: cover;
    object-position: 56% 52%;
  }

  .hero-home__media--empty {
    display: grid;
    place-items: end start;
    padding: 1.3rem;
  }

  .hero-home__media--empty::before,
  .hero-home__media--empty::after {
    display: none;
  }

  .hero-home__media--empty span {
    border: 1px solid rgb(255 250 244 / 0.18);
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    background: rgb(21 17 15 / 0.34);
    color: rgb(255 250 244 / 0.78);
    font-size: 0.9rem;
    font-weight: 760;
  }

  @media (min-width: 760px) {
    h1 {
      font-size: 3.25rem;
    }

    p {
      font-size: 1.14rem;
    }
  }

  @media (min-width: 1180px) {
    h1 {
      font-size: 4rem;
    }
  }

  @media (max-width: 860px) {
    .hero-home__frame {
      min-height: auto;
      grid-template-columns: 1fr;
    }

    .hero-home__media {
      min-height: 16rem;
    }

    .hero-home__media img {
      min-height: 16rem;
      object-position: 52% 48%;
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: 2.2rem;
    }

    p {
      font-size: 1rem;
    }

    .hero-home__actions {
      flex-direction: column;
    }
  }
</style>
