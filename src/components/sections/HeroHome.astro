---
import Button from '@/components/ui/Button.astro';
import Tag from '@/components/ui/Tag.astro';
import type { ImageAsset } from '@/data/assets';

interface Props {
  title?: string;
  description?: string;
  image?: ImageAsset;
}

const {
  title = 'Bauunternehmen für Renovierung, Sanierung und Ausbau in Freilassing',
  description = 'Vrebo Bau begleitet private und gewerbliche Projekte in der Region mit klarer Abstimmung, sauberer Ausführung und einem realistischen Blick auf den Ablauf.',
  image,
} = Astro.props;
---

<section class="hero-home">
  <div class="hero-home__stage">
    <div class:list={['hero-home__media', { 'hero-home__media--empty': !image }]}>
      {image ? (
        <img
          src={image.src}
          alt={image.alt}
          width={image.width}
          height={image.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <span>Projektmotiv</span>
      )}
    </div>

    <img
      class="hero-home__building"
      src="/images/brand/vrebo-building-mark.webp"
      alt=""
      width="1400"
      height="581"
      loading="eager"
      decoding="async"
      aria-hidden="true"
    />

    <div class="hero-home__content">
      <div class="hero-home__label">
        <Tag variant="dark">Vrebo Bau Freilassing</Tag>
        <span>Renovierung / Sanierung / Ausbau</span>
      </div>
      <h1>{title}</h1>
      <p>{description}</p>
      <div class="hero-home__actions" aria-label="Primäre Aktionen">
        <Button href="/kontakt" variant="dark" size="lg">Projekt anfragen</Button>
        <Button href="/leistungen" variant="ghost" size="lg">Leistungen ansehen</Button>
      </div>
    </div>

    <div class="hero-home__trustbar" aria-label="Vertrauenssignale">
      <article>
        <span>01</span>
        <strong>Direkte Abstimmung</strong>
        <p>Ein Ansprechpartner, klare Rückmeldung, geordnete nächste Schritte.</p>
      </article>
      <article>
        <span>02</span>
        <strong>Saubere Ausführung</strong>
        <p>Vorbereitet, geschützt und mit Blick auf Bestand und Alltag umgesetzt.</p>
      </article>
      <article>
        <span>03</span>
        <strong>Regional erreichbar</strong>
        <p>Freilassing, Bad Reichenhall und Berchtesgadener Land im Fokus.</p>
      </article>
    </div>
  </div>
</section>

<style>
  .hero-home {
    overflow: hidden;
    padding: 0;
    background:
      linear-gradient(180deg, #15110f 0%, #211b18 72%, #fffaf4 100%),
      #15110f;
  }

  .hero-home__stage {
    position: relative;
    isolation: isolate;
    width: 100%;
    min-height: clamp(44rem, 100svh, 58rem);
    overflow: hidden;
    border: 0;
    border-radius: 0;
    background:
      linear-gradient(135deg, #15110f 0%, #211b18 48%, #2b090b 100%),
      #15110f;
    color: #fffaf4;
    box-shadow: none;
  }

  .hero-home__stage::before {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgb(21 17 15 / 0.95) 0%, rgb(21 17 15 / 0.86) 31%, rgb(21 17 15 / 0.56) 58%, rgb(21 17 15 / 0.18) 100%),
      linear-gradient(180deg, rgb(21 17 15 / 0.12), rgb(21 17 15 / 0.78));
    content: "";
  }

  .hero-home__stage::after {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgb(255 250 244 / 0.045) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 250 244 / 0.034) 1px, transparent 1px);
    background-size: 5.8rem 5.8rem;
    content: "";
    mask-image: linear-gradient(90deg, black, transparent 70%);
    opacity: 0.78;
  }

  .hero-home__media {
    position: absolute;
    inset: 0;
    z-index: -2;
    overflow: hidden;
    background:
      linear-gradient(145deg, #d6c6b4, #ab3743 62%, #651113);
  }

  .hero-home__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 62% 48%;
    filter: saturate(0.92) contrast(1.06) brightness(0.92);
    transform: scale(1.005);
  }

  .hero-home__building {
    position: absolute;
    right: max(-7rem, -8vw);
    bottom: clamp(4rem, 10vw, 8rem);
    z-index: 0;
    width: min(42rem, 54vw);
    opacity: 0.14;
    mix-blend-mode: screen;
    pointer-events: none;
  }

  .hero-home__content {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: center;
    min-height: clamp(28.5rem, 56vh, 38rem);
    width: min(calc(100% - 2.25rem), var(--site-wide));
    max-width: var(--site-wide);
    min-width: 0;
    margin-inline: auto;
    padding: clamp(8rem, 12vw, 10rem) 0 clamp(10rem, 14vw, 11.5rem);
  }

  .hero-home__label {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-home__label > span {
    min-width: 0;
    color: rgb(255 250 244 / 0.56);
    font-size: 0.78rem;
    font-weight: 760;
    line-height: 1.35;
    text-transform: uppercase;
  }

  h1 {
    width: 100%;
    max-width: 52rem;
    margin: 1.25rem 0 0;
    color: #fffaf4;
    font-size: 2.75rem;
    font-weight: 790;
    letter-spacing: 0;
    line-height: 1.02;
    overflow-wrap: break-word;
  }

  p {
    max-width: 40rem;
    margin: 1.35rem 0 0;
    color: rgb(255 250 244 / 0.8);
    font-size: 1.08rem;
    line-height: 1.68;
  }

  .hero-home__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .hero-home__actions :global(.ui-button--ghost) {
    border-color: rgb(255 250 244 / 0.22);
    background: rgb(255 250 244 / 0.08);
    color: #fffaf4;
    box-shadow: none;
  }

  .hero-home__actions :global(.ui-button--ghost:hover) {
    border-color: rgb(255 250 244 / 0.36);
    background: rgb(255 250 244 / 0.14);
  }

  .hero-home__trustbar {
    position: absolute;
    right: auto;
    bottom: clamp(1rem, 2vw, 1.5rem);
    left: 50%;
    width: min(calc(100% - 2rem), var(--site-wide));
    margin-inline: auto;
    transform: translateX(-50%);
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid rgb(255 250 244 / 0.16);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, rgb(255 250 244 / 0.12), rgb(255 250 244 / 0.06)),
      rgb(21 17 15 / 0.58);
    backdrop-filter: blur(18px);
  }

  .hero-home__trustbar article {
    min-width: 0;
    padding: clamp(0.95rem, 2vw, 1.25rem);
  }

  .hero-home__trustbar article + article {
    border-left: 1px solid rgb(255 250 244 / 0.13);
  }

  .hero-home__trustbar span {
    color: #e8b4b8;
    font-size: 0.78rem;
    font-weight: 840;
  }

  .hero-home__trustbar strong {
    display: block;
    margin-top: 0.35rem;
    color: #fffaf4;
    font-size: 1rem;
    letter-spacing: 0;
  }

  .hero-home__trustbar p {
    margin: 0.35rem 0 0;
    color: rgb(255 250 244 / 0.66);
    font-size: 0.9rem;
    line-height: 1.48;
  }

  .hero-home__media--empty {
    display: grid;
    place-items: end start;
    padding: 1.3rem;
  }

  .hero-home__media--empty span {
    border: 1px solid rgb(255 250 244 / 0.18);
    border-radius: 999px;
    padding: 0.5rem 0.75rem;
    background: rgb(21 17 15 / 0.34);
    color: rgb(255 250 244 / 0.78);
    font-size: 0.9rem;
    font-weight: 760;
  }

  @media (min-width: 760px) {
    h1 {
      font-size: 3.95rem;
    }

    p {
      font-size: 1.14rem;
    }
  }

  @media (min-width: 1180px) {
    h1 {
      font-size: 5.28rem;
    }
  }

  @media (max-width: 900px) {
    .hero-home__stage {
      min-height: clamp(42rem, 100svh, 54rem);
    }

    .hero-home__stage::before {
      background:
        linear-gradient(180deg, rgb(21 17 15 / 0.62), rgb(21 17 15 / 0.94) 56%, rgb(21 17 15 / 0.98)),
        linear-gradient(90deg, rgb(21 17 15 / 0.5), transparent);
    }

    .hero-home__content {
      min-height: 35rem;
      width: min(calc(100% - 1.25rem), var(--site-wide));
      margin-inline: auto;
      padding-top: clamp(7rem, 18vw, 8.6rem);
      padding-bottom: clamp(2rem, 6vw, 3rem);
    }

    .hero-home__media img {
      object-position: 64% 38%;
    }

    .hero-home__building {
      width: 80vw;
      opacity: 0.1;
    }

    .hero-home__trustbar {
      position: relative;
      inset: auto;
      width: auto;
      transform: none;
      grid-template-columns: 1fr;
      margin: 0 clamp(0.8rem, 2vw, 1.25rem) clamp(0.8rem, 2vw, 1.25rem);
    }

    .hero-home__trustbar article + article {
      border-top: 1px solid rgb(255 250 244 / 0.13);
      border-left: 0;
    }
  }

  @media (max-width: 640px) {
    .hero-home__content {
      min-height: 34rem;
      padding-top: clamp(6.25rem, 23vw, 7.4rem);
      padding-right: 1.35rem;
      padding-left: 1.35rem;
    }

    .hero-home__label {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.55rem;
    }

    .hero-home__label > span {
      width: 100%;
      font-size: 0.68rem;
    }

    h1 {
      font-size: clamp(1.62rem, 7.2vw, 2.12rem);
      line-height: 1.08;
      overflow-wrap: anywhere;
    }

    p {
      font-size: 1rem;
    }

    .hero-home__actions {
      flex-direction: column;
    }
  }
</style>
