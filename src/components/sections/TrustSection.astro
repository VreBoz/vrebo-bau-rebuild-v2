---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import SurfaceCard from '@/components/ui/SurfaceCard.astro';
import { trustItems, type TrustItem } from '@/data/sections';

interface Props {
  items?: TrustItem[];
  home?: boolean;
}

const { items = trustItems, home = false } = Astro.props;
---

<section class:list={['trust-section', 'section-shell', { 'section-band': !home, 'trust-section--home': home }]}>
  {home ? (
    <div class="site-container trust-section__home-grid">
      <div class="trust-section__home-copy">
        <SectionHeading
          eyebrow="Warum Vrebo"
          title="Mehr Ruhe im Projekt, weil die Abstimmung vor der Ausführung stimmt"
          description="Gerade im Bestand entscheidet nicht nur das Gewerk. Wichtig ist, dass Umfang, Reihenfolge, Schutz der Bereiche und Übergabe sauber geklärt sind."
          tone="dark"
        />
        <div class="trust-section__region">
          <img src="/images/brand/vrebo-wordmark.png" alt="" width="720" height="214" loading="lazy" decoding="async" />
          <p>Regionaler Fokus: Freilassing, Bad Reichenhall, Berchtesgadener Land und nahe Salzburg Umgebung.</p>
        </div>
      </div>

      <div class="trust-section__home-items">
        {items.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  ) : (
    <div class="site-container trust-section__grid">
      <SectionHeading
        eyebrow="Warum Vrebo"
        title="Verlässliche Arbeit beginnt mit klarer Abstimmung"
        description="Vor einem Projekt zählen nicht nur Material und Ausführung, sondern auch Erreichbarkeit, Vorbereitung und ein sauberer Umgang mit dem Bestand."
      />
      <div class="trust-section__items">
        {items.map((item, index) => (
          <SurfaceCard variant="paper">
            <span class="trust-index">{String(index + 1).padStart(2, '0')}</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </SurfaceCard>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .trust-section--home {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(135deg, #15110f 0%, #211b18 54%, #2b090b 100%),
      #15110f;
    color: #fffaf4;
  }

  .trust-section--home::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      var(--brand-silhouette) right bottom / min(54rem, 84vw) auto no-repeat,
      linear-gradient(90deg, rgb(255 250 244 / 0.045) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 250 244 / 0.034) 1px, transparent 1px);
    background-size: min(54rem, 84vw) auto, 5rem 5rem, 5rem 5rem;
    content: "";
    mask-image: linear-gradient(90deg, transparent, black 36%, transparent);
    opacity: 0.42;
  }

  .trust-section__home-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: end;
  }

  .trust-section__home-copy {
    display: grid;
    gap: clamp(1.5rem, 4vw, 2.6rem);
  }

  .trust-section__region {
    max-width: 30rem;
    border-top: 1px solid rgb(255 250 244 / 0.15);
    padding-top: 1.35rem;
  }

  .trust-section__region img {
    width: 8.2rem;
    height: auto;
    border: 1px solid rgb(255 250 244 / 0.14);
    border-radius: var(--radius-md);
    background: #fffaf4;
    padding: 0.5rem 0.62rem;
  }

  .trust-section__region p {
    margin: 1rem 0 0;
    color: rgb(255 250 244 / 0.68);
    line-height: 1.66;
  }

  .trust-section__home-items {
    display: grid;
    gap: 0.85rem;
  }

  .trust-section__home-items article {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(255 250 244 / 0.14);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(135deg, rgb(255 250 244 / 0.09), rgb(255 250 244 / 0.035)),
      rgb(255 250 244 / 0.045);
    padding: clamp(1.2rem, 2.5vw, 1.55rem);
    box-shadow: 0 24px 62px rgb(0 0 0 / 0.16);
  }

  .trust-section__home-items article::before {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.24rem;
    background: linear-gradient(180deg, #e8b4b8, rgb(171 55 67 / 0.28));
    content: "";
  }

  .trust-section__home-items span {
    display: block;
    color: #e8b4b8;
    font-size: 0.8rem;
    font-weight: 840;
  }

  .trust-section__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .trust-section__items {
    display: grid;
    gap: 0.95rem;
  }

  .trust-section__items :global(.surface-card) {
    position: relative;
    overflow: hidden;
    padding-left: clamp(1.25rem, 3vw, 1.7rem);
  }

  .trust-section__items :global(.surface-card)::after {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.26rem;
    background: linear-gradient(180deg, #ab3743, rgb(101 17 19 / 0.28));
    content: "";
  }

  .trust-index {
    display: block;
    margin-bottom: 0.65rem;
    color: #ab3743;
    font-size: 0.82rem;
    font-weight: 820;
  }

  h3 {
    margin: 0;
    color: #2b090b;
    font-size: 1.12rem;
    font-weight: 820;
    letter-spacing: 0;
  }

  p {
    margin: 0.45rem 0 0;
    color: #6b625c;
    line-height: 1.62;
  }

  .trust-section__home-items h3 {
    margin-top: 0.65rem;
    color: #fffaf4;
  }

  .trust-section__home-items p {
    color: rgb(255 250 244 / 0.68);
  }

  @media (max-width: 820px) {
    .trust-section__grid,
    .trust-section__home-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
