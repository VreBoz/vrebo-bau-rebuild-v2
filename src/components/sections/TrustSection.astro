---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import SurfaceCard from '@/components/ui/SurfaceCard.astro';
import { trustItems, type TrustItem } from '@/data/sections';

interface Props {
  items?: TrustItem[];
}

const { items = trustItems } = Astro.props;
---

<section class="trust-section section-shell section-band">
  <div class="site-container trust-section__grid">
    <SectionHeading
      eyebrow="Warum Vrebo"
      title="Verlässliche Arbeit beginnt mit klarer Abstimmung"
      description="Vor einem Projekt zählen nicht nur Material und Ausführung, sondern auch Erreichbarkeit, Vorbereitung und ein sauberer Umgang mit dem Bestand."
    />
    <div class="trust-section__items">
      {items.map((item, index) => (
        <SurfaceCard variant="paper">
          <span class="trust-index">{String(index + 1).padStart(2, '0')}</span>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </SurfaceCard>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-section__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .trust-section__items {
    display: grid;
    gap: 0.95rem;
  }

  .trust-section__items :global(.surface-card) {
    position: relative;
    overflow: hidden;
    padding-left: clamp(1.25rem, 3vw, 1.7rem);
  }

  .trust-section__items :global(.surface-card)::after {
    position: absolute;
    inset: 0 auto 0 0;
    width: 0.26rem;
    background: linear-gradient(180deg, #ab3743, rgb(101 17 19 / 0.28));
    content: "";
  }

  .trust-index {
    display: block;
    margin-bottom: 0.65rem;
    color: #ab3743;
    font-size: 0.82rem;
    font-weight: 820;
  }

  h3 {
    margin: 0;
    color: #2b090b;
    font-size: 1.12rem;
    font-weight: 820;
    letter-spacing: 0;
  }

  p {
    margin: 0.45rem 0 0;
    color: #6b625c;
    line-height: 1.62;
  }

  @media (max-width: 820px) {
    .trust-section__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
