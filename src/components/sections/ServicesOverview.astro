---
import type { CollectionEntry } from 'astro:content';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import ServiceCard from '@/components/ui/ServiceCard.astro';
import Button from '@/components/ui/Button.astro';
import LinkArrow from '@/components/ui/LinkArrow.astro';
import Tag from '@/components/ui/Tag.astro';

interface Props {
  services: CollectionEntry<'services'>[];
  eyebrow?: string;
  title?: string;
  description?: string;
  limit?: number;
  compact?: boolean;
  band?: boolean;
  showAllLink?: boolean;
  home?: boolean;
}

const {
  services,
  eyebrow = 'Leistungen',
  title = 'Leistungen für Ausbau, Sanierung und Modernisierung',
  description = 'Die Übersicht führt zu den wichtigsten Bereichen und hält bewusst kurze Beschreibungen bereit, damit der passende Einstieg schnell gefunden ist.',
  limit,
  compact = false,
  band = false,
  showAllLink = true,
  home = false,
} = Astro.props;
const visibleServices = typeof limit === 'number' ? services.slice(0, limit) : services;

const getHomeTitle = (service: CollectionEntry<'services'>) => {
  if (service.data.slug === 'hausmeisterservice-objektpflege') {
    return 'Hausmeisterservice & Objektpflege';
  }

  if (service.data.slug === 'abdichtung-feuchtigkeitsschutz') {
    return 'Abdichtung & Feuchtigkeitsschutz';
  }

  return service.data.navLabel;
};

const fallbackImages: Record<string, NonNullable<CollectionEntry<'services'>['data']['heroImage']>> = {
  'hausmeisterservice-objektpflege': {
    src: '/images/services/aussenanlagen-plattenweg.webp',
    alt: 'Gepflegter Außenbereich mit Plattenweg am Haus',
    width: 1200,
    height: 1200,
  },
};

const homeServices = visibleServices.map((service) => ({
  service,
  title: getHomeTitle(service),
  image: service.data.heroImage ?? fallbackImages[service.data.slug],
}));
---

<section class:list={['services-overview', 'section-shell', { 'section-band': band, 'services-overview--home': home }]}>
  <div class="site-container">
    <div class="services-overview__head">
      <SectionHeading eyebrow={eyebrow} title={title} description={description} />
      {showAllLink && <Button href="/leistungen" variant="secondary">{home ? 'Alle Leistungen ansehen' : 'Alle Leistungen'}</Button>}
    </div>

    {home ? (
      <div class="services-overview__home-grid">
        {homeServices.map(({ service, title, image }, index) => (
          <article class="services-overview__home-card">
            <a class="services-overview__home-media" href={`/leistungen/${service.data.slug}`} aria-label={`${service.data.title} öffnen`}>
              {image && (
                <img
                  src={image.src}
                  alt={image.alt}
                  loading="eager"
                  decoding="async"
                  fetchpriority={index < 4 ? 'high' : 'auto'}
                  width={image.width}
                  height={image.height}
                />
              )}
            </a>
            <div class="services-overview__home-body">
              <div class="services-overview__home-tags">
                {service.data.tags.slice(0, 2).map((tag) => <Tag variant="warm">{tag}</Tag>)}
              </div>
              <h3><a href={`/leistungen/${service.data.slug}`}>{title}</a></h3>
              <p>{service.data.description}</p>
              <LinkArrow href={`/leistungen/${service.data.slug}`}>Leistung ansehen</LinkArrow>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class:list={['services-overview__grid', { 'services-overview__grid--compact': compact }]}>
        {visibleServices.map((service, index) => (
          <ServiceCard service={service} index={index} compact={compact} />
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .services-overview--home {
    padding-top: clamp(4.25rem, 8vw, 7.25rem);
  }

  .services-overview__head {
    position: relative;
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    border-bottom: 1px solid rgb(48 43 40 / 0.1);
    padding-bottom: clamp(1.25rem, 3vw, 2rem);
  }

  .services-overview__head::after {
    position: absolute;
    right: 0;
    bottom: -1px;
    width: min(16rem, 42vw);
    height: 2px;
    background: linear-gradient(90deg, transparent, #ab3743);
    content: "";
  }

  .services-overview__home-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.35rem);
    margin-top: clamp(1.6rem, 3vw, 2.35rem);
  }

  .services-overview__home-card {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    min-width: 0;
    min-height: 100%;
    overflow: hidden;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background: var(--surface-paper);
    box-shadow: var(--shadow-soft);
    transition:
      border-color var(--motion-duration) var(--ease-vrebo),
      box-shadow var(--motion-duration) var(--ease-vrebo),
      transform var(--motion-duration) var(--ease-vrebo);
  }

  .services-overview__home-card:hover {
    border-color: rgb(101 17 19 / 0.22);
    box-shadow: var(--shadow-card);
    transform: translateY(-2px);
  }

  .services-overview__home-media {
    display: block;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgb(233 223 210 / 0.8), rgb(255 250 244 / 0.7)),
      #e9dfd2;
  }

  .services-overview__home-media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.94) contrast(1.03);
    transition: transform var(--motion-duration-long) var(--ease-vrebo);
  }

  .services-overview__home-card:hover .services-overview__home-media img {
    transform: scale(1.035);
  }

  .services-overview__home-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: clamp(1.05rem, 2vw, 1.28rem);
  }

  .services-overview__home-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    min-height: 1.8rem;
    margin-bottom: 0.9rem;
  }

  .services-overview__home-tags :global(.tag) {
    min-height: 1.55rem;
    padding: 0.28rem 0.56rem;
    font-size: 0.74rem;
  }

  .services-overview__home-card h3 {
    margin: 0;
    color: #2b090b;
    font-size: clamp(1.08rem, 1.5vw, 1.2rem);
    font-weight: 840;
    line-height: 1.14;
    overflow-wrap: break-word;
  }

  .services-overview__home-card p {
    display: -webkit-box;
    flex: 1 1 auto;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    margin: 0.65rem 0 1.05rem;
    color: #6b625c;
    font-size: 0.98rem;
    line-height: 1.58;
  }

  .services-overview__home-card :global(.link-arrow) {
    margin-top: auto;
    color: #651113;
  }

  .services-overview__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.35rem);
    margin-top: clamp(1.4rem, 3vw, 2.2rem);
  }

  .services-overview__grid--compact {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.25rem);
  }

  @media (max-width: 1120px) {
    .services-overview__home-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .services-overview__home-grid,
    .services-overview__grid,
    .services-overview__grid--compact {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .services-overview__head {
      align-items: stretch;
      flex-direction: column;
    }

    .services-overview__home-grid,
    .services-overview__grid,
    .services-overview__grid--compact {
      grid-template-columns: 1fr;
    }

    .services-overview__head :global(.section-heading h2) {
      max-width: 100%;
      font-size: 1.45rem;
      line-height: 1.08;
      overflow-wrap: anywhere;
    }
  }
</style>
