---
import Button from '@/components/ui/Button.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

interface Props {
  title?: string;
  description?: string;
  home?: boolean;
}

const {
  title = 'Nächster Schritt: Projekt kurz schildern',
  description = 'Beschreiben Sie kurz, worum es geht. Fotos, Ort und gewünschter Zeitraum helfen bei der ersten Einschätzung.',
  home = false,
} = Astro.props;
---

<section class:list={['final-cta', 'section-shell--compact', { 'final-cta--home': home }]}>
  <div class:list={['site-container', 'final-cta__frame', { 'final-cta__frame--home': home }]}>
    <div class="final-cta__copy">
      {home && (
        <div class="final-cta__brand">Vrebo</div>
      )}
      <SectionHeading eyebrow="Kontakt" title={title} description={description} tone="dark" />
    </div>

    <div class="final-cta__side">
      {home && (
        <div class="final-cta__micro">
          <span>Projektstart</span>
          <p>Kurze Beschreibung, Ort und Fotos genügen für die erste Einordnung.</p>
        </div>
      )}
      <div class="final-cta__actions">
        <Button href="/kontakt" variant="dark" size="lg">Kontakt öffnen</Button>
        <Button href="/leistungen" variant="ghost" size="lg">Leistungen ansehen</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background:
      linear-gradient(180deg, transparent 0%, rgb(244 239 232 / 0.72) 100%),
      #fffaf4;
  }

  .final-cta__frame {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border: 1px solid rgb(255 250 244 / 0.12);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgb(101 17 19 / 0.86), rgb(21 17 15 / 0.98) 62%),
      #15110f;
    padding: clamp(1.5rem, 5vw, 3.2rem);
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .final-cta__frame--home {
    align-items: end;
    min-height: clamp(21rem, 32vw, 28rem);
    background:
      linear-gradient(135deg, rgb(43 9 11 / 0.92), rgb(21 17 15 / 0.98) 58%),
      #15110f;
  }

  .final-cta__frame::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      var(--brand-silhouette) right bottom / min(34rem, 70vw) auto no-repeat,
      linear-gradient(90deg, rgb(255 250 244 / 0.055) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 250 244 / 0.04) 1px, transparent 1px);
    background-size: min(34rem, 70vw) auto, 4.8rem 4.8rem, 4.8rem 4.8rem;
    content: "";
    mask-image: linear-gradient(90deg, transparent, black 36%, transparent);
    opacity: 0.54;
  }

  .final-cta__frame--home::before {
    position: absolute;
    right: -5rem;
    bottom: 2.4rem;
    width: min(48rem, 62vw);
    height: 20rem;
    pointer-events: none;
    background: url("/images/brand/vrebo-building-mark.webp") center / contain no-repeat;
    content: "";
    mix-blend-mode: screen;
    opacity: 0.15;
  }

  .final-cta__copy,
  .final-cta__side,
  .final-cta__frame :global(.section-heading),
  .final-cta__actions {
    position: relative;
    z-index: 1;
  }

  .final-cta__copy {
    display: grid;
    gap: 0.95rem;
  }

  .final-cta__brand {
    color: #fffaf4;
    font-family: var(--font-brand);
    font-size: clamp(5rem, 11vw, 8rem);
    line-height: 0.58;
  }

  .final-cta__side {
    display: grid;
    justify-items: end;
    gap: 1.2rem;
  }

  .final-cta__micro {
    max-width: 22rem;
    border: 1px solid rgb(255 250 244 / 0.14);
    border-radius: var(--radius-lg);
    background: rgb(255 250 244 / 0.07);
    padding: 1rem 1.1rem;
  }

  .final-cta__micro span {
    display: block;
    color: #e8b4b8;
    font-size: 0.78rem;
    font-weight: 840;
    text-transform: uppercase;
  }

  .final-cta__micro p {
    margin: 0.45rem 0 0;
    color: rgb(255 250 244 / 0.7);
    line-height: 1.55;
  }

  .final-cta__actions {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .final-cta__actions :global(.ui-button--ghost) {
    border-color: rgb(255 250 244 / 0.2);
    background: rgb(255 250 244 / 0.08);
    color: #fffaf4;
    box-shadow: none;
  }

  .final-cta__actions :global(.ui-button--ghost:hover) {
    border-color: rgb(255 250 244 / 0.36);
    background: rgb(255 250 244 / 0.14);
  }

  @media (max-width: 820px) {
    .final-cta__frame {
      align-items: stretch;
      flex-direction: column;
    }

    .final-cta__side {
      justify-items: stretch;
    }

    .final-cta__actions {
      flex-direction: column;
    }
  }
</style>
