---
import Button from '@/components/ui/Button.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Nächster Schritt: Projekt kurz schildern',
  description = 'Beschreiben Sie kurz, worum es geht. Fotos, Ort und gewünschter Zeitraum helfen bei der ersten Einschätzung.',
} = Astro.props;
---

<section class="final-cta section-shell--compact">
  <div class="site-container final-cta__frame">
    <SectionHeading eyebrow="Kontakt" title={title} description={description} tone="dark" />
    <div class="final-cta__actions">
      <Button href="/kontakt" variant="dark" size="lg">Kontakt öffnen</Button>
      <Button href="/leistungen" variant="ghost" size="lg">Leistungen ansehen</Button>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background:
      linear-gradient(180deg, transparent 0%, rgb(244 239 232 / 0.72) 100%),
      #fffaf4;
  }

  .final-cta__frame {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    border: 1px solid rgb(255 250 244 / 0.12);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgb(101 17 19 / 0.86), rgb(21 17 15 / 0.98) 62%),
      #15110f;
    padding: clamp(1.5rem, 5vw, 3.2rem);
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .final-cta__frame::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgb(255 250 244 / 0.055) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 250 244 / 0.04) 1px, transparent 1px);
    background-size: 4.8rem 4.8rem;
    content: "";
    mask-image: linear-gradient(90deg, transparent, black 36%, transparent);
  }

  .final-cta__frame :global(.section-heading),
  .final-cta__actions {
    position: relative;
    z-index: 1;
  }

  .final-cta__actions {
    display: flex;
    flex: 0 0 auto;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @media (max-width: 820px) {
    .final-cta__frame {
      align-items: stretch;
      flex-direction: column;
    }

    .final-cta__actions {
      flex-direction: column;
    }
  }
</style>
