---
import Button from '@/components/ui/Button.astro';
import Tag from '@/components/ui/Tag.astro';

type HeroAction = {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'dark';
};

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  tags?: string[];
  actions?: ReadonlyArray<HeroAction>;
  tone?: 'light' | 'dark';
  mediaLabel?: string;
}

const {
  eyebrow,
  title,
  description,
  tags = [],
  actions = [],
  tone = 'light',
  mediaLabel = 'Bild- oder Projektflaeche',
} = Astro.props;
const hasMedia = Astro.slots.has('media');
---

<section class:list={['page-hero', `page-hero--${tone}`]}>
  <div class="site-container page-hero__grid">
    <div class="page-hero__copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {description && <p class="page-hero__description">{description}</p>}
      {tags.length > 0 && (
        <div class="page-hero__tags" aria-label="Seitenschwerpunkte">
          {tags.map((tag) => <Tag variant={tone === 'dark' ? 'dark' : 'light'}>{tag}</Tag>)}
        </div>
      )}
      {actions.length > 0 && (
        <div class="page-hero__actions">
          {actions.map((action) => (
            <Button href={action.href} variant={action.variant ?? (tone === 'dark' ? 'dark' : 'primary')}>
              {action.label}
            </Button>
          ))}
        </div>
      )}
    </div>

    <div class="page-hero__media" aria-label={mediaLabel}>
      {hasMedia ? <slot name="media" /> : <span>{mediaLabel}</span>}
    </div>
  </div>
</section>

<style>
  .page-hero {
    padding-block: var(--section-y-compact);
    background: #fffaf4;
  }

  .page-hero--dark {
    background: #15110f;
    color: #fffaf4;
  }

  .page-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.48fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }

  .page-hero__copy {
    min-width: 0;
  }

  h1 {
    max-width: 58rem;
    margin: 0;
    color: #15110f;
    font-size: 2.45rem;
    font-weight: 820;
    letter-spacing: 0;
    line-height: 1;
  }

  .page-hero--dark h1 {
    color: #fffaf4;
  }

  .page-hero__description {
    max-width: 45rem;
    margin: 1.2rem 0 0;
    color: #6b625c;
    font-size: 1.08rem;
  }

  .page-hero--dark .page-hero__description {
    color: rgb(255 250 244 / 0.74);
  }

  .page-hero__tags,
  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.35rem;
  }

  .page-hero__actions {
    margin-top: 2rem;
  }

  .page-hero__media {
    display: grid;
    min-height: 18rem;
    place-items: center;
    overflow: hidden;
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(145deg, rgb(48 43 40 / 0.08), rgb(101 17 19 / 0.1)),
      #e9dfd2;
    color: #6b625c;
    font-weight: 780;
    text-align: center;
  }

  .page-hero--dark .page-hero__media {
    border-color: rgb(255 250 244 / 0.14);
    background:
      linear-gradient(145deg, rgb(255 250 244 / 0.1), rgb(171 55 67 / 0.22)),
      #211b18;
    color: rgb(255 250 244 / 0.72);
  }

  @media (min-width: 760px) {
    h1 {
      font-size: 3.45rem;
    }

    .page-hero__description {
      font-size: 1.14rem;
    }
  }

  @media (min-width: 1180px) {
    h1 {
      font-size: 4.35rem;
    }
  }

  @media (max-width: 820px) {
    .page-hero__grid {
      grid-template-columns: 1fr;
    }

    .page-hero__media {
      min-height: 13rem;
    }
  }
</style>
