---
import Button from '@/components/ui/Button.astro';
import Tag from '@/components/ui/Tag.astro';
import type { ImageAsset } from '@/data/assets';

type HeroAction = {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost' | 'dark';
};

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  tags?: string[];
  actions?: ReadonlyArray<HeroAction>;
  tone?: 'light' | 'dark';
  mediaLabel?: string;
  image?: ImageAsset;
}

const {
  eyebrow,
  title,
  description,
  tags = [],
  actions = [],
  tone = 'light',
  mediaLabel = 'Bild- oder Projektfläche',
  image,
} = Astro.props;
const hasMedia = Astro.slots.has('media');
---

<section class:list={['page-hero', `page-hero--${tone}`]}>
  <div class="site-container page-hero__grid">
    <div class="page-hero__copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      {description && <p class="page-hero__description">{description}</p>}
      {tags.length > 0 && (
        <div class="page-hero__tags" aria-label="Seitenschwerpunkte">
          {tags.map((tag) => <Tag variant={tone === 'dark' ? 'dark' : 'light'}>{tag}</Tag>)}
        </div>
      )}
      {actions.length > 0 && (
        <div class="page-hero__actions">
          {actions.map((action) => (
            <Button href={action.href} variant={action.variant ?? (tone === 'dark' ? 'dark' : 'primary')}>
              {action.label}
            </Button>
          ))}
        </div>
      )}
    </div>

    <div
      class:list={['page-hero__media', { 'page-hero__media--empty': !image && !hasMedia }]}
      aria-label={!image && !hasMedia ? mediaLabel : undefined}
    >
      {image ? (
        <img
          src={image.src}
          alt={image.alt}
          width={image.width}
          height={image.height}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : hasMedia ? (
        <slot name="media" />
      ) : (
        <span>{mediaLabel}</span>
      )}
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-block: var(--section-y-compact);
    background:
      linear-gradient(180deg, rgb(255 250 244 / 0.96), rgb(244 239 232 / 0.34)),
      #fffaf4;
  }

  .page-hero--dark {
    background:
      linear-gradient(135deg, #15110f 0%, #211b18 58%, #2b090b 100%),
      #15110f;
    color: #fffaf4;
  }

  .page-hero__grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(19rem, 0.52fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }

  .page-hero__copy {
    min-width: 0;
  }

  h1 {
    max-width: 58rem;
    margin: 0;
    color: #15110f;
    font-size: 2.45rem;
    font-weight: 840;
    letter-spacing: 0;
    line-height: 1.01;
  }

  .page-hero--dark h1 {
    color: #fffaf4;
  }

  .page-hero__description {
    max-width: 45rem;
    margin: 1.2rem 0 0;
    color: #6b625c;
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .page-hero--dark .page-hero__description {
    color: rgb(255 250 244 / 0.74);
  }

  .page-hero__tags,
  .page-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.35rem;
  }

  .page-hero__actions {
    margin-top: 2rem;
  }

  .page-hero__media {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3.15;
    min-height: 18rem;
    overflow: hidden;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(145deg, rgb(48 43 40 / 0.08), rgb(101 17 19 / 0.1)),
      #e9dfd2;
    color: #6b625c;
    font-weight: 780;
    box-shadow: var(--shadow-card);
    text-align: center;
  }

  .page-hero__media::after {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, transparent 48%, rgb(21 17 15 / 0.16)),
      linear-gradient(90deg, rgb(21 17 15 / 0.12), transparent 42%);
    content: "";
  }

  .page-hero__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    min-height: 18rem;
    object-fit: cover;
    object-position: center 52%;
  }

  .page-hero__media--empty {
    display: grid;
    place-items: center;
  }

  .page-hero__media--empty::after {
    display: none;
  }

  .page-hero--dark .page-hero__media {
    border-color: rgb(255 250 244 / 0.14);
    background:
      linear-gradient(145deg, rgb(255 250 244 / 0.1), rgb(171 55 67 / 0.22)),
      #211b18;
    color: rgb(255 250 244 / 0.72);
    box-shadow: var(--shadow-dark);
  }

  @media (min-width: 760px) {
    h1 {
      font-size: 3.45rem;
    }

    .page-hero__description {
      font-size: 1.14rem;
    }
  }

  @media (min-width: 1180px) {
    h1 {
      font-size: 4.35rem;
    }
  }

  @media (max-width: 820px) {
    .page-hero__grid {
      grid-template-columns: 1fr;
    }

    .page-hero__media {
      aspect-ratio: 16 / 10;
      min-height: 13rem;
    }

    .page-hero__media img {
      min-height: 13rem;
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: 2.12rem;
    }
  }
</style>
