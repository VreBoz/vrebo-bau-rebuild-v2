---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import Button from '@/components/ui/Button.astro';
import { commonFaq, type FaqItem } from '@/data/sections';

interface Props {
  items?: FaqItem[];
  home?: boolean;
}

const { items = commonFaq, home = false } = Astro.props;
---

<section class:list={['faq-section', 'section-shell', { 'faq-section--home': home }]}>
  <div class:list={['site-container', { 'faq-section__frame': home }]}>
    <div class:list={['faq-section__grid', { 'faq-section__grid--home': home }]}>
      <div class="faq-section__intro">
        <SectionHeading
          eyebrow="FAQ"
          title="Häufige Fragen vor der Anfrage"
          description="Kurze Antworten helfen, den ersten Kontakt vorzubereiten und typische Unsicherheiten früh zu klären."
          tone={home ? 'dark' : 'default'}
        />
        {home && (
          <div class="faq-section__hint">
            <strong>Direkt starten</strong>
            <p>Wenn die Frage spezieller ist, reicht eine kurze Projektskizze. Vrebo meldet sich persönlich zurück.</p>
            <Button href="/kontakt" variant="ghost">Projekt schildern</Button>
          </div>
        )}
      </div>

      <div class="faq-section__items">
        {items.map((item) => (
          <details>
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-section--home {
    background:
      linear-gradient(180deg, rgb(244 239 232 / 0.58) 0%, #fffaf4 44%, rgb(244 239 232 / 0.52) 100%),
      #fffaf4;
  }

  .faq-section__frame {
    position: relative;
    overflow: hidden;
    border: 1px solid rgb(255 250 244 / 0.13);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(135deg, rgb(43 9 11 / 0.94), rgb(21 17 15 / 0.98) 58%, #211b18 100%),
      #15110f;
    padding: clamp(1.15rem, 4vw, 2.4rem);
    color: #fffaf4;
    box-shadow: var(--shadow-dark);
  }

  .faq-section__frame::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      var(--brand-silhouette) left bottom / min(32rem, 70vw) auto no-repeat,
      linear-gradient(90deg, rgb(255 250 244 / 0.048) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 250 244 / 0.035) 1px, transparent 1px);
    background-size: min(32rem, 70vw) auto, 4.8rem 4.8rem, 4.8rem 4.8rem;
    content: "";
    mask-image: linear-gradient(90deg, black, transparent 68%);
    opacity: 0.42;
  }

  .faq-section__grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .faq-section__grid--home {
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: clamp(1.6rem, 5vw, 4.4rem);
  }

  .faq-section__intro {
    display: grid;
    gap: clamp(1.35rem, 3vw, 2rem);
    min-width: 0;
  }

  .faq-section__grid--home :global(.section-heading h2) {
    max-width: 12ch;
    font-size: clamp(2.25rem, 4.4vw, 3.15rem);
  }

  .faq-section__grid--home :global(.section-heading__description) {
    max-width: 31rem;
  }

  .faq-section__hint {
    align-self: start;
    max-width: 31rem;
    border-top: 1px solid rgb(255 250 244 / 0.17);
    padding-top: clamp(1.1rem, 2.5vw, 1.35rem);
  }

  .faq-section__hint strong {
    display: block;
    color: #fffaf4;
    font-size: 1.05rem;
  }

  .faq-section__hint p {
    margin: 0.45rem 0 1.1rem;
    padding: 0;
    color: rgb(255 250 244 / 0.68);
  }

  .faq-section__hint :global(.ui-button--ghost) {
    border-color: rgb(255 250 244 / 0.2);
    background: rgb(255 250 244 / 0.08);
    color: #fffaf4;
    box-shadow: none;
  }

  .faq-section__hint :global(.ui-button--ghost:hover) {
    border-color: rgb(255 250 244 / 0.36);
    background: rgb(255 250 244 / 0.14);
  }

  .faq-section__items {
    display: grid;
    gap: 0.65rem;
    min-width: 0;
  }

  details {
    overflow: hidden;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-md);
    background: var(--surface-paper);
    box-shadow: var(--shadow-soft);
    transition:
      border-color var(--motion-duration) var(--ease-vrebo),
      box-shadow var(--motion-duration) var(--ease-vrebo),
      background-color var(--motion-duration) var(--ease-vrebo);
  }

  .faq-section__grid--home details {
    border-color: rgb(255 250 244 / 0.13);
    background:
      linear-gradient(135deg, rgb(255 250 244 / 0.08), rgb(255 250 244 / 0.032)),
      rgb(255 250 244 / 0.045);
    box-shadow: none;
  }

  details[open],
  details:hover {
    border-color: rgb(101 17 19 / 0.2);
    box-shadow: var(--shadow-card);
  }

  .faq-section__grid--home details[open],
  .faq-section__grid--home details:hover {
    border-color: rgb(232 180 184 / 0.34);
    background:
      linear-gradient(135deg, rgb(255 250 244 / 0.105), rgb(255 250 244 / 0.045)),
      rgb(255 250 244 / 0.06);
    box-shadow: 0 20px 50px rgb(0 0 0 / 0.16);
  }

  summary {
    position: relative;
    cursor: pointer;
    list-style: none;
    padding: clamp(1rem, 2vw, 1.15rem) 3.25rem clamp(1rem, 2vw, 1.15rem) clamp(1.05rem, 2vw, 1.35rem);
    color: #2b090b;
    font-weight: 800;
    line-height: 1.32;
  }

  .faq-section__grid--home summary {
    color: #fffaf4;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    position: absolute;
    top: 50%;
    right: 1rem;
    display: grid;
    width: 1.8rem;
    height: 1.8rem;
    place-items: center;
    transform: translateY(-50%);
    border: 1px solid rgb(101 17 19 / 0.16);
    border-radius: 999px;
    background: rgb(101 17 19 / 0.055);
    color: #651113;
    content: "+";
    font-weight: 820;
  }

  .faq-section__grid--home summary::after {
    border-color: rgb(255 250 244 / 0.18);
    background: rgb(255 250 244 / 0.07);
    color: #e8b4b8;
  }

  details[open] summary::after {
    content: "-";
  }

  p {
    margin: 0;
    padding: 0 clamp(1.05rem, 2vw, 1.35rem) clamp(1rem, 2vw, 1.25rem);
    color: #6b625c;
    line-height: 1.66;
  }

  .faq-section__grid--home details p {
    color: rgb(255 250 244 / 0.68);
  }

  .faq-section__hint p {
    margin: 0.45rem 0 1.1rem;
    padding: 0;
  }

  @media (max-width: 820px) {
    .faq-section__grid,
    .faq-section__grid--home {
      grid-template-columns: 1fr;
    }

    .faq-section__grid--home :global(.section-heading h2) {
      max-width: 100%;
    }
  }

  @media (max-width: 520px) {
    .faq-section__frame {
      width: min(calc(100% - 0.75rem), var(--site-max));
      max-width: calc(100vw - 0.75rem);
      padding: 1rem;
    }

    .faq-section__grid--home :global(.section-heading h2) {
      font-size: 1.72rem;
      overflow-wrap: anywhere;
    }

    summary {
      padding-right: 2.8rem;
    }
  }
</style>
