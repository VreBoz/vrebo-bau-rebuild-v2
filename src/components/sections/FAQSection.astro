---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { commonFaq, type FaqItem } from '@/data/sections';

interface Props {
  items?: FaqItem[];
}

const { items = commonFaq } = Astro.props;
---

<section class="faq-section section-shell">
  <div class="site-container faq-section__grid">
    <SectionHeading
      eyebrow="FAQ"
      title="Fragen fuer die naechste Inhaltsphase"
      description="Die FAQ-Komponente nutzt native Details-Elemente und funktioniert ohne JavaScript."
    />
    <div class="faq-section__items">
      {items.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .faq-section__items {
    display: grid;
    gap: 0.75rem;
  }

  details {
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    background: rgb(255 250 244 / 0.9);
  }

  summary {
    cursor: pointer;
    padding: 1rem 1.1rem;
    color: #2b090b;
    font-weight: 800;
  }

  p {
    margin: 0;
    padding: 0 1.1rem 1rem;
    color: #6b625c;
  }

  @media (max-width: 820px) {
    .faq-section__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
