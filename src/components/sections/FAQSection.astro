---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { commonFaq, type FaqItem } from '@/data/sections';

interface Props {
  items?: FaqItem[];
}

const { items = commonFaq } = Astro.props;
---

<section class="faq-section section-shell">
  <div class="site-container faq-section__grid">
    <SectionHeading
      eyebrow="FAQ"
      title="Häufige Fragen vor der Anfrage"
      description="Kurze Antworten helfen, den ersten Kontakt vorzubereiten und typische Unsicherheiten früh zu klären."
    />
    <div class="faq-section__items">
      {items.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .faq-section__items {
    display: grid;
    gap: 0.85rem;
  }

  details {
    overflow: hidden;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-lg);
    background: var(--surface-paper);
    box-shadow: var(--shadow-soft);
  }

  summary {
    position: relative;
    cursor: pointer;
    list-style: none;
    padding: 1.05rem 3rem 1.05rem 1.15rem;
    color: #2b090b;
    font-weight: 800;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    position: absolute;
    top: 50%;
    right: 1rem;
    display: grid;
    width: 1.8rem;
    height: 1.8rem;
    place-items: center;
    transform: translateY(-50%);
    border: 1px solid rgb(101 17 19 / 0.16);
    border-radius: 999px;
    background: rgb(101 17 19 / 0.055);
    color: #651113;
    content: "+";
    font-weight: 820;
  }

  details[open] summary::after {
    content: "-";
  }

  p {
    margin: 0;
    padding: 0 1.15rem 1.15rem;
    color: #6b625c;
    line-height: 1.66;
  }

  @media (max-width: 820px) {
    .faq-section__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
