---
import { SITE } from '@/data/site';
import { legalNavigation, mainNavigation, serviceNavigation } from '@/data/navigation';
---

<footer class="site-footer">
  <div class="site-container footer-grid">
    <div class="footer-brand">
      <a class="footer-logo" href="/" aria-label={`${SITE.name} Startseite`}>
        <img
          src="/images/brand/vrebo-wordmark.png"
          alt=""
          width="720"
          height="214"
          loading="lazy"
          decoding="async"
        />
      </a>
      <p>Renovierung, Sanierung und Ausbau mit regionalem Schwerpunkt in Freilassing und Umgebung.</p>
      <a class="footer-primary" href="/kontakt">Projekt anfragen</a>
    </div>

    <nav aria-label="Footer Navigation">
      <h2>Seiten</h2>
      {mainNavigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <nav aria-label="Leistungen im Footer">
      <h2>Leistungen</h2>
      {serviceNavigation.filter((item) => !item.optional).slice(0, 7).map((item) => (
        <a href={item.href}>{item.navLabel}</a>
      ))}
    </nav>

    <div>
      <h2>Region</h2>
      <p>{SITE.areaServed.join(' / ')}</p>
      <a class="footer-contact" href="/kontakt">Kontaktseite öffnen</a>
    </div>
  </div>

  <div class="site-container footer-bottom">
    <span>{new Date().getFullYear()} {SITE.name}</span>
    <nav aria-label="Rechtliche Links">
      {legalNavigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(135deg, #15110f 0%, #211b18 56%, #2b090b 100%),
      #15110f;
    color: #fffaf4;
  }

  .site-footer::before {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgb(255 250 244 / 0.045) 1px, transparent 1px),
      linear-gradient(180deg, rgb(255 250 244 / 0.035) 1px, transparent 1px);
    background-size: 5rem 5rem;
    content: "";
    mask-image: linear-gradient(180deg, black, transparent 80%);
  }

  .footer-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) repeat(3, minmax(0, 1fr));
    gap: clamp(2rem, 5vw, 4rem);
    padding-block: clamp(3.5rem, 8vw, 6rem);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgb(255 250 244 / 0.12);
    border-radius: var(--radius-md);
    background: #fffaf4;
    padding: 0.6rem 0.76rem;
    box-shadow: 0 18px 40px rgb(0 0 0 / 0.2);
  }

  .footer-logo img {
    display: block;
    width: 7.6rem;
    height: auto;
  }

  .footer-brand p,
  .site-footer p {
    max-width: 24rem;
    margin: 1.15rem 0 0;
    color: rgb(255 250 244 / 0.72);
    line-height: 1.68;
  }

  .site-footer h2 {
    margin: 0 0 0.9rem;
    color: rgb(255 250 244 / 0.92);
    font-size: 0.82rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .site-footer nav {
    display: grid;
    align-content: start;
    gap: 0.55rem;
  }

  .site-footer a {
    color: rgb(255 250 244 / 0.78);
    width: fit-content;
    transition:
      color var(--motion-duration) var(--ease-vrebo),
      transform var(--motion-duration) var(--ease-vrebo);
  }

  .site-footer a:hover {
    color: #ffffff;
    transform: translateX(0.12rem);
  }

  .footer-logo:hover {
    transform: none;
  }

  .footer-primary,
  .footer-contact {
    display: inline-flex;
    margin-top: 1.2rem;
    color: #ffffff;
    font-weight: 760;
  }

  .footer-primary {
    align-items: center;
    border: 1px solid rgb(255 250 244 / 0.18);
    border-radius: 999px;
    padding: 0.72rem 1rem;
    background: rgb(255 250 244 / 0.08);
  }

  .footer-bottom {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid rgb(255 250 244 / 0.14);
    padding-block: 1.2rem;
    color: rgb(255 250 244 / 0.64);
    font-size: 0.9rem;
  }

  .footer-bottom nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (max-width: 840px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
