---
import { SITE } from '@/data/site';
import { mainNavigation, serviceNavigation } from '@/data/navigation';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const normalizePath = (path: string) => path.replace(/\/$/, '') || '/';
const normalizedCurrent = normalizePath(currentPath);
const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  return normalizedHref === '/'
    ? normalizedCurrent === '/'
    : normalizedCurrent === normalizedHref || normalizedCurrent.startsWith(`${normalizedHref}/`);
};
---

<header class="site-header">
  <div class="site-container header-inner">
    <a class="brand-link" href="/" aria-label={`${SITE.name} Startseite`}>
      <img
        class="brand-logo"
        src="/images/brand/vrebo-wordmark.png"
        alt=""
        width="720"
        height="214"
        decoding="async"
      />
      <span class="brand-copy">
        <small>Bau Freilassing</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {mainNavigation.map((item) => (
        item.href === '/leistungen' ? (
          <details class="nav-dropdown">
            <summary class:list={['nav-link', { 'is-active': isActive(item.href) }]}>
              {item.label}
            </summary>
            <div class="dropdown-panel">
              <a class="dropdown-overview" href={item.href}>Alle Leistungen</a>
              <div class="dropdown-grid">
                {serviceNavigation.filter((service) => !service.optional).map((service) => (
                  <a href={service.href}>{service.navLabel}</a>
                ))}
              </div>
            </div>
          </details>
        ) : (
          <a class:list={['nav-link', { 'is-active': isActive(item.href) }]} href={item.href}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <a class="button button--primary header-cta" href={SITE.navigationCta.href}>
      {SITE.navigationCta.label}
    </a>

    <details class="mobile-nav">
      <summary aria-label="Menü öffnen">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-panel">
        {mainNavigation.map((item) => (
          <a class:list={{ 'is-active': isActive(item.href) }} href={item.href}>{item.label}</a>
        ))}
        <div class="mobile-services" aria-label="Leistungsnavigation">
          {serviceNavigation.filter((service) => !service.optional).map((service) => (
            <a href={service.href}>{service.navLabel}</a>
          ))}
        </div>
        <a class="button button--primary" href={SITE.navigationCta.href}>{SITE.navigationCta.label}</a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    padding-block: 0.55rem;
    background: linear-gradient(180deg, rgb(255 250 244 / 0.94), rgb(255 250 244 / 0.8));
    backdrop-filter: blur(18px);
  }

  .header-inner {
    position: relative;
    display: flex;
    min-height: calc(var(--header-height) - 1.1rem);
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.35rem);
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.42), transparent 62%),
      rgb(255 250 244 / 0.92);
    padding: 0.42rem 0.52rem 0.42rem clamp(0.68rem, 1.8vw, 0.95rem);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.78) inset,
      0 18px 48px rgb(21 17 15 / 0.07);
  }

  .brand-link {
    display: inline-flex;
    min-width: max-content;
    align-items: center;
    gap: 0.82rem;
    border-radius: 999px;
    font-weight: 820;
  }

  .brand-logo {
    display: block;
    width: clamp(7.5rem, 13vw, 10.2rem);
    height: auto;
  }

  .brand-copy {
    display: grid;
    gap: 0.05rem;
    line-height: 1;
  }

  .brand-copy small {
    color: #651113;
    font-size: 0.72rem;
    font-weight: 760;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .desktop-nav {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    gap: 0.18rem;
    min-width: 0;
  }

  .nav-link,
  .nav-dropdown summary {
    position: relative;
    border-radius: 999px;
    padding: 0.74rem 0.98rem;
    color: #302b28;
    font-size: 0.95rem;
    font-weight: 760;
    line-height: 1;
    list-style: none;
    cursor: pointer;
    transition:
      background-color var(--motion-duration) var(--ease-vrebo),
      color var(--motion-duration) var(--ease-vrebo);
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-link:hover,
  .nav-dropdown[open] summary,
  .nav-dropdown summary:hover {
    background: rgb(101 17 19 / 0.06);
    color: #651113;
  }

  .nav-link.is-active,
  .nav-dropdown summary.is-active {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.5), transparent 74%),
      rgb(101 17 19 / 0.08);
    color: #651113;
    box-shadow: 0 1px 0 rgb(255 255 255 / 0.72) inset;
  }

  .nav-dropdown {
    position: relative;
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 50%;
    width: min(36rem, calc(100vw - 2rem));
    padding: 1.1rem;
    transform: translateX(-50%);
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-xl);
    background: rgb(255 250 244 / 0.97);
    box-shadow: var(--shadow-lift);
  }

  .dropdown-overview {
    display: block;
    border-bottom: 1px solid rgb(48 43 40 / 0.1);
    padding: 0.25rem 0.42rem 0.95rem;
    color: #651113;
    font-weight: 800;
  }

  .dropdown-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.2rem 0.6rem;
    padding-top: 0.75rem;
  }

  .dropdown-grid a,
  .mobile-services a {
    border-radius: var(--radius-sm);
    padding: 0.7rem 0.78rem;
    color: #302b28;
    font-weight: 720;
    transition:
      background-color var(--motion-duration) var(--ease-vrebo),
      color var(--motion-duration) var(--ease-vrebo);
  }

  .dropdown-grid a:hover,
  .mobile-services a:hover {
    background: rgb(233 223 210 / 0.6);
    color: #651113;
  }

  .header-cta {
    min-width: max-content;
    min-height: 2.85rem;
    padding-inline: 1.22rem;
    box-shadow: 0 1px 0 rgb(255 255 255 / 0.18) inset, 0 14px 30px rgb(101 17 19 / 0.2);
  }

  .mobile-nav {
    display: none;
    margin-left: auto;
    position: relative;
  }

  .mobile-nav summary {
    display: grid;
    width: 2.85rem;
    height: 2.85rem;
    place-items: center;
    border: 1px solid rgb(101 17 19 / 0.22);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.5), transparent 70%),
      #fffaf4;
    box-shadow: 0 10px 24px rgb(101 17 19 / 0.1);
    list-style: none;
    cursor: pointer;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav summary span {
    width: 1.1rem;
    height: 0.1rem;
    margin: -0.25rem 0;
    border-radius: 999px;
    background: #2b090b;
  }

  .mobile-nav[open] summary {
    background: #651113;
  }

  .mobile-nav[open] summary span {
    background: #fffaf4;
  }

  .mobile-panel {
    position: absolute;
    top: calc(100% + 0.8rem);
    right: 0;
    width: min(22rem, calc(100vw - 2rem));
    padding: 1.1rem;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-xl);
    background: rgb(255 250 244 / 0.98);
    box-shadow: var(--shadow-lift);
  }

  .mobile-panel > a:not(.button) {
    display: block;
    border-radius: var(--radius-sm);
    padding: 0.82rem 0.85rem;
    font-weight: 760;
  }

  .mobile-panel > a:not(.button):hover {
    background: rgb(233 223 210 / 0.52);
    color: #651113;
  }

  .mobile-panel > a.is-active {
    background: rgb(101 17 19 / 0.08);
    color: #651113;
  }

  .mobile-services {
    display: grid;
    gap: 0.1rem;
    margin: 0.5rem 0 1rem;
    border-block: 1px solid rgb(48 43 40 / 0.1);
    padding-block: 0.6rem;
  }

  @media (max-width: 920px) {
    .desktop-nav,
    .header-cta {
      display: none;
    }

    .mobile-nav {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      padding-block: 0.45rem;
    }

    .header-inner {
      min-height: calc(var(--header-height) - 0.9rem);
      padding: 0.38rem 0.45rem 0.38rem 0.68rem;
    }

    .brand-copy {
      display: none;
    }

    .brand-logo {
      width: clamp(6.8rem, 34vw, 8rem);
    }

    .mobile-panel {
      width: min(22rem, calc(100vw - 1.25rem));
      right: -0.2rem;
    }
  }
</style>
