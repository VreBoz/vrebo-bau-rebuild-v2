---
import { SITE } from '@/data/site';
import { mainNavigation, serviceNavigation } from '@/data/navigation';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const normalizePath = (path: string) => path.replace(/\/$/, '') || '/';
const normalizedCurrent = normalizePath(currentPath);
const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  return normalizedHref === '/'
    ? normalizedCurrent === '/'
    : normalizedCurrent === normalizedHref || normalizedCurrent.startsWith(`${normalizedHref}/`);
};
---

<header class="site-header">
  <div class="site-container header-inner">
    <a class="brand-link" href="/" aria-label={`${SITE.name} Startseite`}>
      <img
        class="brand-logo"
        src="/images/brand/vrebo-wordmark.png"
        alt=""
        width="720"
        height="214"
        decoding="async"
      />
      <span class="brand-copy">
        <small>Bau Freilassing</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {mainNavigation.map((item) => (
        item.href === '/leistungen' ? (
          <details class="nav-dropdown">
            <summary class:list={['nav-link', { 'is-active': isActive(item.href) }]}>
              {item.label}
            </summary>
            <div class="dropdown-panel">
              <a class="dropdown-overview" href={item.href}>Alle Leistungen</a>
              <div class="dropdown-grid">
                {serviceNavigation.filter((service) => !service.optional).map((service) => (
                  <a href={service.href}>{service.navLabel}</a>
                ))}
              </div>
            </div>
          </details>
        ) : (
          <a class:list={['nav-link', { 'is-active': isActive(item.href) }]} href={item.href}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <a class="button button--primary header-cta" href={SITE.navigationCta.href}>
      {SITE.navigationCta.label}
    </a>

    <details class="mobile-nav">
      <summary aria-label="Menue oeffnen">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-panel">
        {mainNavigation.map((item) => (
          <a class:list={{ 'is-active': isActive(item.href) }} href={item.href}>{item.label}</a>
        ))}
        <div class="mobile-services" aria-label="Leistungsnavigation">
          {serviceNavigation.filter((service) => !service.optional).map((service) => (
            <a href={service.href}>{service.navLabel}</a>
          ))}
        </div>
        <a class="button button--primary" href={SITE.navigationCta.href}>{SITE.navigationCta.label}</a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    min-height: var(--header-height);
    border-bottom: 1px solid rgb(48 43 40 / 0.1);
    background: rgb(255 250 244 / 0.88);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    display: flex;
    min-height: var(--header-height);
    align-items: center;
    gap: 1rem;
  }

  .brand-link {
    display: inline-flex;
    min-width: max-content;
    align-items: center;
    gap: 0.7rem;
    font-weight: 820;
  }

  .brand-logo {
    display: block;
    width: clamp(6.2rem, 12vw, 8.2rem);
    height: auto;
  }

  .brand-copy {
    display: grid;
    gap: 0.05rem;
    line-height: 1;
  }

  .brand-copy small {
    color: #6b625c;
    font-size: 0.72rem;
    font-weight: 680;
  }

  .desktop-nav {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
  }

  .nav-link,
  .nav-dropdown summary {
    border-radius: 999px;
    padding: 0.68rem 0.88rem;
    color: #302b28;
    font-size: 0.95rem;
    font-weight: 720;
    line-height: 1;
    list-style: none;
    cursor: pointer;
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-link:hover,
  .nav-link.is-active,
  .nav-dropdown[open] summary,
  .nav-dropdown summary.is-active {
    background: rgb(101 17 19 / 0.08);
    color: #651113;
  }

  .nav-dropdown {
    position: relative;
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 0.75rem);
    left: 50%;
    width: min(36rem, calc(100vw - 2rem));
    padding: 1rem;
    transform: translateX(-50%);
    border: 1px solid rgb(48 43 40 / 0.12);
    border-radius: var(--radius-lg);
    background: #fffaf4;
    box-shadow: var(--shadow-lift);
  }

  .dropdown-overview {
    display: block;
    border-bottom: 1px solid rgb(48 43 40 / 0.1);
    padding: 0.25rem 0.25rem 0.85rem;
    color: #651113;
    font-weight: 800;
  }

  .dropdown-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.2rem 0.6rem;
    padding-top: 0.75rem;
  }

  .dropdown-grid a,
  .mobile-services a {
    border-radius: var(--radius-sm);
    padding: 0.62rem 0.7rem;
    color: #302b28;
    font-weight: 680;
  }

  .dropdown-grid a:hover,
  .mobile-services a:hover {
    background: rgb(233 223 210 / 0.6);
    color: #651113;
  }

  .header-cta {
    min-width: max-content;
  }

  .mobile-nav {
    display: none;
    margin-left: auto;
    position: relative;
  }

  .mobile-nav summary {
    display: grid;
    width: 2.75rem;
    height: 2.75rem;
    place-items: center;
    border: 1px solid rgb(48 43 40 / 0.14);
    border-radius: 999px;
    background: #fffaf4;
    list-style: none;
    cursor: pointer;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav summary span {
    width: 1.1rem;
    height: 0.1rem;
    margin: -0.25rem 0;
    border-radius: 999px;
    background: #2b090b;
  }

  .mobile-panel {
    position: absolute;
    top: calc(100% + 0.8rem);
    right: 0;
    width: min(22rem, calc(100vw - 2rem));
    padding: 1rem;
    border: 1px solid rgb(48 43 40 / 0.12);
    border-radius: var(--radius-lg);
    background: #fffaf4;
    box-shadow: var(--shadow-lift);
  }

  .mobile-panel > a:not(.button) {
    display: block;
    border-radius: var(--radius-sm);
    padding: 0.72rem 0.75rem;
    font-weight: 760;
  }

  .mobile-panel > a.is-active {
    background: rgb(101 17 19 / 0.08);
    color: #651113;
  }

  .mobile-services {
    display: grid;
    gap: 0.1rem;
    margin: 0.5rem 0 1rem;
    border-block: 1px solid rgb(48 43 40 / 0.1);
    padding-block: 0.6rem;
  }

  @media (max-width: 920px) {
    .desktop-nav,
    .header-cta {
      display: none;
    }

    .mobile-nav {
      display: block;
    }
  }
</style>
