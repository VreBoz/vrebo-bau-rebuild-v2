---
import { SITE } from '@/data/site';
import { mainNavigation, serviceNavigation } from '@/data/navigation';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;
const normalizePath = (path: string) => path.replace(/\/$/, '') || '/';
const normalizedCurrent = normalizePath(currentPath);
const isHome = normalizedCurrent === '/';
const brandLogo = isHome
  ? { src: '/images/brand/vrebo-wordmark-outline.png', width: 372, height: 120 }
  : { src: '/images/brand/vrebo-wordmark.png', width: 720, height: 214 };
const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  return normalizedHref === '/'
    ? normalizedCurrent === '/'
    : normalizedCurrent === normalizedHref || normalizedCurrent.startsWith(`${normalizedHref}/`);
};
---

<header class:list={['site-header', { 'site-header--home': isHome }]}>
  <div class="site-container header-inner">
    <a class="brand-link" href="/" aria-label={`${SITE.name} Startseite`}>
      <img
        class="brand-logo"
        src={brandLogo.src}
        alt=""
        width={brandLogo.width}
        height={brandLogo.height}
        decoding="async"
      />
      {isHome ? (
        <img
          class="brand-sublogo"
          src="/images/brand/vrebo-bau-freilassing-outline.png"
          alt=""
          width="330"
          height="50"
          decoding="async"
        />
      ) : (
        <span class="brand-copy">
          <small>Bau Freilassing</small>
        </span>
      )}
    </a>

    <nav class="desktop-nav" aria-label="Hauptnavigation">
      {mainNavigation.map((item) => (
        item.href === '/leistungen' ? (
          <details class="nav-dropdown">
            <summary class:list={['nav-link', { 'is-active': isActive(item.href) }]}>
              {item.label}
            </summary>
            <div class="dropdown-panel">
              <a class="dropdown-overview" href={item.href}>Alle Leistungen</a>
              <div class="dropdown-grid">
                {serviceNavigation.filter((service) => !service.optional).map((service) => (
                  <a href={service.href}>{service.navLabel}</a>
                ))}
              </div>
            </div>
          </details>
        ) : (
          <a class:list={['nav-link', { 'is-active': isActive(item.href) }]} href={item.href}>
            {item.label}
          </a>
        )
      ))}
    </nav>

    <a class="button button--primary header-cta" href={SITE.navigationCta.href}>
      {SITE.navigationCta.label}
    </a>

    <details class="mobile-nav">
      <summary aria-label="Menü öffnen">
        <span></span>
        <span></span>
        <span></span>
      </summary>
      <div class="mobile-panel">
        {mainNavigation.map((item) => (
          <a class:list={{ 'is-active': isActive(item.href) }} href={item.href}>{item.label}</a>
        ))}
        <div class="mobile-services" aria-label="Leistungsnavigation">
          {serviceNavigation.filter((service) => !service.optional).map((service) => (
            <a href={service.href}>{service.navLabel}</a>
          ))}
        </div>
        <a class="button button--primary" href={SITE.navigationCta.href}>{SITE.navigationCta.label}</a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 70;
    padding-block: 0.38rem;
    background: linear-gradient(180deg, rgb(255 250 244 / 0.94), rgb(255 250 244 / 0.74));
    backdrop-filter: blur(16px);
  }

  .site-header--home {
    position: fixed;
    right: 0;
    left: 0;
    padding-block: clamp(0.72rem, 1.6vw, 1.05rem);
    background: linear-gradient(180deg, rgb(21 17 15 / 0.34), transparent);
    backdrop-filter: none;
  }

  .header-inner {
    position: relative;
    display: flex;
    min-height: calc(var(--header-height) - 1.55rem);
    align-items: center;
    gap: clamp(0.65rem, 1.8vw, 1.15rem);
    border: 1px solid rgb(48 43 40 / 0.085);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.36), transparent 66%),
      rgb(255 250 244 / 0.9);
    padding: 0.32rem 0.42rem 0.32rem clamp(0.62rem, 1.6vw, 0.82rem);
    box-shadow:
      0 1px 0 rgb(255 255 255 / 0.72) inset,
      0 12px 34px rgb(21 17 15 / 0.055);
  }

  .site-header--home .header-inner {
    border-color: rgb(255 250 244 / 0.12);
    background:
      linear-gradient(180deg, rgb(255 250 244 / 0.055), transparent 70%),
      rgb(21 17 15 / 0.82);
    box-shadow:
      0 1px 0 rgb(255 250 244 / 0.1) inset,
      0 24px 60px rgb(0 0 0 / 0.28);
    backdrop-filter: blur(16px);
  }

  .brand-link {
    display: inline-flex;
    min-width: max-content;
    align-items: center;
    gap: 0.82rem;
    border-radius: 999px;
    font-weight: 820;
  }

  .site-header--home .brand-link {
    gap: clamp(0.38rem, 0.8vw, 0.58rem);
  }

  .brand-logo {
    display: block;
    width: clamp(7.1rem, 11.5vw, 9.35rem);
    height: auto;
  }

  .site-header--home .brand-logo {
    width: clamp(6.7rem, 10.4vw, 8.45rem);
    filter: drop-shadow(0 5px 12px rgb(0 0 0 / 0.24));
  }

  .brand-sublogo {
    display: block;
    width: clamp(4.8rem, 7vw, 6rem);
    height: auto;
    margin-top: 0.08rem;
    opacity: 0.96;
    filter: drop-shadow(0 5px 12px rgb(0 0 0 / 0.2));
  }

  .brand-copy {
    display: grid;
    gap: 0.05rem;
    line-height: 1;
  }

  .brand-copy small {
    color: #651113;
    font-size: 0.69rem;
    font-weight: 760;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .desktop-nav {
    display: flex;
    flex: 1;
    align-items: center;
    justify-content: center;
    gap: 0.18rem;
    min-width: 0;
  }

  .nav-link,
  .nav-dropdown summary {
    position: relative;
    border-radius: 999px;
    padding: 0.66rem 0.86rem;
    color: #302b28;
    font-size: 0.93rem;
    font-weight: 730;
    line-height: 1;
    list-style: none;
    cursor: pointer;
    transition:
      background-color var(--motion-duration) var(--ease-vrebo),
      color var(--motion-duration) var(--ease-vrebo);
  }

  .site-header--home .nav-link,
  .site-header--home .nav-dropdown summary {
    color: rgb(255 250 244 / 0.82);
  }

  .nav-dropdown summary::-webkit-details-marker {
    display: none;
  }

  .nav-link:hover,
  .nav-dropdown[open] summary,
  .nav-dropdown summary:hover {
    background: rgb(101 17 19 / 0.06);
    color: #651113;
  }

  .nav-link.is-active,
  .nav-dropdown summary.is-active {
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.5), transparent 74%),
      rgb(101 17 19 / 0.062);
    color: #651113;
    box-shadow: 0 1px 0 rgb(255 255 255 / 0.72) inset;
  }

  .site-header--home .nav-link:hover,
  .site-header--home .nav-dropdown[open] summary,
  .site-header--home .nav-dropdown summary:hover {
    background: rgb(255 250 244 / 0.085);
    color: #fffaf4;
  }

  .site-header--home .nav-link.is-active,
  .site-header--home .nav-dropdown summary.is-active {
    background: rgb(255 250 244 / 0.12);
    color: #fffaf4;
    box-shadow: 0 1px 0 rgb(255 250 244 / 0.12) inset;
  }

  .nav-dropdown {
    position: relative;
  }

  .dropdown-panel {
    position: absolute;
    top: calc(100% + 0.62rem);
    left: 50%;
    width: min(36rem, calc(100vw - 2rem));
    padding: 1.1rem;
    transform: translateX(-50%);
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-xl);
    background: rgb(255 250 244 / 0.97);
    box-shadow: var(--shadow-lift);
  }

  .site-header--home .dropdown-panel {
    border-color: rgb(255 250 244 / 0.14);
    background:
      linear-gradient(180deg, rgb(255 250 244 / 0.06), transparent 58%),
      rgb(21 17 15 / 0.94);
    box-shadow: 0 26px 70px rgb(0 0 0 / 0.34);
  }

  .dropdown-overview {
    display: block;
    border-bottom: 1px solid rgb(48 43 40 / 0.1);
    padding: 0.25rem 0.42rem 0.95rem;
    color: #651113;
    font-weight: 800;
  }

  .site-header--home .dropdown-overview {
    border-bottom-color: rgb(255 250 244 / 0.12);
    color: #fffaf4;
  }

  .dropdown-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.2rem 0.6rem;
    padding-top: 0.75rem;
  }

  .dropdown-grid a,
  .mobile-services a {
    border-radius: var(--radius-sm);
    padding: 0.7rem 0.78rem;
    color: #302b28;
    font-weight: 720;
    transition:
      background-color var(--motion-duration) var(--ease-vrebo),
      color var(--motion-duration) var(--ease-vrebo);
  }

  .site-header--home .dropdown-grid a {
    color: rgb(255 250 244 / 0.78);
  }

  .dropdown-grid a:hover,
  .mobile-services a:hover {
    background: rgb(233 223 210 / 0.6);
    color: #651113;
  }

  .site-header--home .dropdown-grid a:hover {
    background: rgb(255 250 244 / 0.08);
    color: #fffaf4;
  }

  .header-cta {
    min-width: max-content;
    min-height: 2.55rem;
    padding-inline: 1.04rem;
    font-size: 0.93rem;
    box-shadow: 0 1px 0 rgb(255 255 255 / 0.16) inset, 0 11px 24px rgb(101 17 19 / 0.17);
  }

  .site-header--home .header-cta {
    border-color: rgb(255 250 244 / 0.18);
    background: #fffaf4;
    color: #2b090b;
    box-shadow: 0 1px 0 rgb(255 255 255 / 0.52) inset, 0 16px 34px rgb(0 0 0 / 0.2);
  }

  .site-header--home .header-cta:hover {
    background: #ffffff;
    color: #2b090b;
  }

  .mobile-nav {
    display: none;
    margin-left: auto;
    position: relative;
  }

  .mobile-nav summary {
    display: grid;
    width: 2.62rem;
    height: 2.62rem;
    place-items: center;
    border: 1px solid rgb(101 17 19 / 0.22);
    border-radius: 999px;
    background:
      linear-gradient(180deg, rgb(255 255 255 / 0.5), transparent 70%),
      #fffaf4;
    box-shadow: 0 10px 24px rgb(101 17 19 / 0.1);
    list-style: none;
    cursor: pointer;
  }

  .site-header--home .mobile-nav summary {
    border-color: rgb(255 250 244 / 0.18);
    background: rgb(255 250 244 / 0.1);
    box-shadow: none;
  }

  .site-header--home .mobile-nav summary span {
    background: #fffaf4;
  }

  .mobile-nav summary::-webkit-details-marker {
    display: none;
  }

  .mobile-nav summary span {
    width: 1.1rem;
    height: 0.1rem;
    margin: -0.25rem 0;
    border-radius: 999px;
    background: #2b090b;
  }

  .mobile-nav[open] summary {
    background: #651113;
  }

  .mobile-nav[open] summary span {
    background: #fffaf4;
  }

  .mobile-panel {
    position: absolute;
    top: calc(100% + 0.8rem);
    right: 0;
    width: min(22rem, calc(100vw - 2rem));
    padding: 1.1rem;
    border: 1px solid rgb(48 43 40 / 0.1);
    border-radius: var(--radius-xl);
    background: rgb(255 250 244 / 0.98);
    box-shadow: var(--shadow-lift);
  }

  .site-header--home .mobile-panel {
    border-color: rgb(255 250 244 / 0.14);
    background:
      linear-gradient(180deg, rgb(255 250 244 / 0.07), transparent 56%),
      rgb(21 17 15 / 0.96);
    box-shadow: 0 26px 70px rgb(0 0 0 / 0.34);
  }

  .mobile-panel > a:not(.button) {
    display: block;
    border-radius: var(--radius-sm);
    padding: 0.82rem 0.85rem;
    font-weight: 760;
  }

  .site-header--home .mobile-panel > a:not(.button),
  .site-header--home .mobile-services a {
    color: rgb(255 250 244 / 0.82);
  }

  .mobile-panel > a:not(.button):hover {
    background: rgb(233 223 210 / 0.52);
    color: #651113;
  }

  .site-header--home .mobile-panel > a:not(.button):hover,
  .site-header--home .mobile-services a:hover {
    background: rgb(255 250 244 / 0.08);
    color: #fffaf4;
  }

  .mobile-panel > a.is-active {
    background: rgb(101 17 19 / 0.08);
    color: #651113;
  }

  .site-header--home .mobile-panel > a.is-active {
    background: rgb(255 250 244 / 0.12);
    color: #fffaf4;
  }

  .site-header--home .mobile-panel .button {
    background: #fffaf4;
    color: #2b090b;
  }

  .mobile-services {
    display: grid;
    gap: 0.1rem;
    margin: 0.5rem 0 1rem;
    border-block: 1px solid rgb(48 43 40 / 0.1);
    padding-block: 0.6rem;
  }

  .site-header--home .mobile-services {
    border-block-color: rgb(255 250 244 / 0.12);
  }

  @media (max-width: 920px) {
    .desktop-nav,
    .header-cta {
      display: none;
    }

    .mobile-nav {
      display: block;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      padding-block: 0.32rem;
    }

    .site-header--home {
      padding-block: 0.55rem;
    }

    .header-inner {
      min-height: calc(var(--header-height) - 1.25rem);
      padding: 0.3rem 0.36rem 0.3rem 0.58rem;
    }

    .brand-copy {
      display: none;
    }

    .brand-sublogo {
      display: none;
    }

    .brand-logo {
      width: clamp(6.55rem, 32vw, 7.5rem);
    }

    .site-header--home .brand-logo {
      width: clamp(6rem, 30vw, 7rem);
    }

    .mobile-panel {
      width: min(22rem, calc(100vw - 1.25rem));
      right: -0.2rem;
    }
  }
</style>
