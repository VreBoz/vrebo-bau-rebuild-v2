---
interface Props {
  href: string;
  label?: string;
  tone?: 'brand' | 'light' | 'dark';
  class?: string;
}

const { href, label, tone = 'brand', class: className = '' } = Astro.props;
---

<a class:list={['link-arrow', `link-arrow--${tone}`, className]} href={href} aria-label={label}>
  <span><slot>{label}</slot></span>
  <svg aria-hidden="true" viewBox="0 0 16 16">
    <path d="M3 8h9M8.5 3.5 13 8l-4.5 4.5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" />
  </svg>
</a>

<style>
  .link-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-weight: 780;
    line-height: 1.2;
  }

  .link-arrow svg {
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
    transition: transform var(--motion-duration) var(--ease-vrebo);
  }

  .link-arrow:hover svg {
    transform: translateX(0.18rem);
  }

  .link-arrow--brand {
    color: #651113;
  }

  .link-arrow--light {
    color: #fffaf4;
  }

  .link-arrow--dark {
    color: #2b090b;
  }
</style>
