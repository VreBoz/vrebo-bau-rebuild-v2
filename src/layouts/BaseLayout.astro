---
import SeoHead from '@/components/layout/SeoHead.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import '@/styles/global.css';

type JsonLd = Record<string, unknown>;

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  jsonLd?: JsonLd | JsonLd[];
}

const { title, description, canonical, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <SiteHeader currentPath={Astro.url.pathname} />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
